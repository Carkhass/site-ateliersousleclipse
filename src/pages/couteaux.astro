---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';

// 1. Récupération sécurisée
const resCouteaux = await getCollection('couteaux').catch(() => []);
// On garde resDivers sous le coude, mais on ne l'injecte plus dans la liste principale
const resDivers = await getCollection('divers').catch(() => []);

// 2. On ne garde QUE les couteaux pour cette page
// NOUVEAU TRI : Disponibles en premier, puis par date décroissante
const tousLesItems = [...(resCouteaux || [])].sort((a, b) => {
  const isDispoA = a.data.disponible === true || String(a.data.disponible) === "true";
  const isDispoB = b.data.disponible === true || String(b.data.disponible) === "true";

  // 1er niveau de tri : Mettre les disponibles en haut
  if (isDispoA && !isDispoB) return -1; // A passe avant B
  if (!isDispoA && isDispoB) return 1;  // B passe avant A

  // 2ème niveau de tri : Si les deux ont le même statut, on trie par date (le plus récent d'abord)
  const dateA = new Date(a.data?.date || 0).getTime();
  const dateB = new Date(b.data?.date || 0).getTime();
  return dateB - dateA;
});

// 3. Filtrage des images valides (inchangé)
const couteauxTries = tousLesItems.filter(item => {
  const img = Array.isArray(item.data.image) ? item.data.image[0] : item.data.image;
  return img && typeof img === 'string' && img.trim() !== '';
});

// Le reste du code (schemaData) utilisera automatiquement 
// uniquement les couteaux grâce à "couteauxTries".

const schemaData = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Les Créations de l'Atelier sous l'Éclipse",
  "numberOfItems": couteauxTries.length,
  "itemListElement": couteauxTries.map((item, index) => {
    const firstImage = Array.isArray(item.data.image) ? item.data.image[0] : item.data.image;
    
    // --- 1. Logique de disponibilité (Dynamique) ---
    const estDispo = item.data.disponible === true || String(item.data.disponible) === "true";
    const availabilityStatus = estDispo ? "https://schema.org/InStock" : "https://schema.org/OutOfStock";
    
    // --- 2. Logique de prix (Google exige un format numérique) ---
    const prixSchema = item.data.prix > 0 ? item.data.prix : "0";

    return {
      "@type": "ListItem",
      "position": index + 1,
      "item": {
        "@type": "Product",
        "name": item.data.titre,
        "image": new URL(firstImage || '', Astro.site || 'https://ateliersousleclipse.fr').href,
        "description": item.data.description || "",
        "brand": {
          "@type": "Brand",
          "name": "L'Atelier sous l'Éclipse"
        },
        // --- 3. LE BLOC OFFERS ATTENDU PAR GOOGLE ---
        "offers": {
          "@type": "Offer",
          "priceCurrency": "EUR",
          "price": prixSchema,
          "availability": availabilityStatus,
          "itemCondition": "https://schema.org/NewCondition",
          "url": Astro.site ? new URL(Astro.url.pathname, Astro.site).href : 'https://ateliersousleclipse.fr/couteaux'
        }
      }
    };
  })
};
