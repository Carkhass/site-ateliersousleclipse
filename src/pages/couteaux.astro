</BaseLayout>


<script>
  import { initFilters } from '../scripts/features/knife-filters.js';
  import { initBookingLogic } from '../scripts/features/booking-modal.js';
  import { initHamonScratcher } from '../scripts/features/hamon-easter-egg.js'; // L'import propre
  import EmblaCarousel from 'embla-carousel';
  import { initEmbla } from '../scripts/init/init-embla.js';
  import GLightbox from 'glightbox';
  import 'glightbox/dist/css/glightbox.min.css';

  let lightboxInstance = null;

  function initAccordion() {
    // Ton code accordéon existant...
    document.querySelectorAll('.toggle-details').forEach(btn => {
      btn.onclick = (e) => {
        e.preventDefault(); e.stopPropagation();
        const content = btn.closest('.knife-card').querySelector('.details-content');
        btn.classList.toggle('active');
        content.classList.toggle('is-open');
        const svg = btn.querySelector('svg');
        if (svg) svg.style.transform = content.classList.contains('is-open') ? 'rotate(180deg)' : 'rotate(0deg)';
      };
    });
  }

  function initPage() {
    document.querySelectorAll('.embla').forEach((root) => initEmbla(root, EmblaCarousel));
    
    initFilters();
    initBookingLogic();
    initAccordion();
    initHamonScratcher(); // On appelle juste la fonction exportée

    if (lightboxInstance) lightboxInstance.destroy();
    lightboxInstance = GLightbox({ 
        selector: 'a.glightbox-insta', 
        skin: 'hamon', 
        touchNavigation: true, 
        loop: true, 
        zoomable: false, 
        draggable: true 
    });
  }

  document.addEventListener('astro:page-load', initPage);
  if (document.readyState !== 'loading') { 
    if (!window.astroPageLoadExecuted) initPage(); 
  } else { 
    document.addEventListener('DOMContentLoaded', initPage); 
  }


  document.addEventListener('DOMContentLoaded', () => {
    const openBtn = document.getElementById('open-club-modal');
    const modal = document.getElementById('club-modal');
    const bg = document.getElementById('close-club-bg');
    const content = document.getElementById('club-modal-content');
    const closeBtn = document.getElementById('close-club-btn');
    const closeSuccessBtn = document.getElementById('close-club-success');
    const form = document.getElementById('club-form');
    const submitBtn = document.getElementById('btn-club');
    const formContainer = document.getElementById('club-form-container');
    const successMsg = document.getElementById('msg-club-success');
    const prenom = document.getElementById('prenom-club').value;

    const WEBHOOK_URL = "https://n8n.yahncloud.fr/webhook/rejoindre-club"; 

    // Fonction pour ouvrir
    function openModal() {
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      // Petit délai pour déclencher la transition CSS
      setTimeout(() => {
        bg.classList.remove('opacity-0');
        content.classList.remove('scale-95', 'opacity-0');
        content.classList.add('scale-100', 'opacity-100');
      }, 10);
    }

    // Fonction pour fermer
    function closeModal() {
      bg.classList.add('opacity-0');
      content.classList.remove('scale-100', 'opacity-100');
      content.classList.add('scale-95', 'opacity-0');
      setTimeout(() => {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
        // Reset du formulaire en douce
        setTimeout(() => {
          formContainer.classList.remove('hidden');
          successMsg.classList.add('hidden');
          form.reset();
        }, 300);
      }, 300);
    }

    // Événements d'ouverture / fermeture
    if(openBtn) openBtn.addEventListener('click', openModal);
    if(closeBtn) closeBtn.addEventListener('click', closeModal);
    if(bg) bg.addEventListener('click', closeModal);
    if(closeSuccessBtn) closeSuccessBtn.addEventListener('click', closeModal);

    // Envoi du formulaire à n8n
    if(form) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        // C'est ICI qu'il faut lire les valeurs, au moment où on clique !
        const prenom = document.getElementById('prenom-club').value;
        const email = document.getElementById('email-club').value;
        
        const originalText = submitBtn.innerText;
        submitBtn.innerText = "Traitement...";
        submitBtn.style.pointerEvents = "none";
        submitBtn.style.opacity = "0.7";

        try {
          await fetch(WEBHOOK_URL, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ prenom: prenom, email: email })
          });
          
          // Succès : on switch le contenu
          formContainer.classList.add('hidden');
          successMsg.classList.remove('hidden');
          
        } catch (error) {
          submitBtn.innerText = "Erreur, réessayez";
          setTimeout(() => { 
            submitBtn.innerText = originalText; 
            submitBtn.style.pointerEvents = "auto";
            submitBtn.style.opacity = "1";
          }, 3000);
        }
      });
    }
  });
</script>
