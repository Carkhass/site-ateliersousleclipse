---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';

// 1. Récupération sécurisée
const resCouteaux = await getCollection('couteaux').catch(() => []);
// On garde resDivers sous le coude, mais on ne l'injecte plus dans la liste principale
const resDivers = await getCollection('divers').catch(() => []);

// 2. On ne garde QUE les couteaux pour cette page
// Le tri reste identique pour avoir les nouveautés en premier
const tousLesItems = [...(resCouteaux || [])].sort((a, b) => {
  const dateA = new Date(a.data?.date || 0).getTime();
  const dateB = new Date(b.data?.date || 0).getTime();
  return dateB - dateA;
});

// 3. Filtrage des images valides (inchangé)
const couteauxTries = tousLesItems.filter(item => {
  const img = Array.isArray(item.data.image) ? item.data.image[0] : item.data.image;
  return img && typeof img === 'string' && img.trim() !== '';
});

// Le reste du code (schemaData) utilisera automatiquement 
// uniquement les couteaux grâce à "couteauxTries".

const schemaData = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Les Créations de l'Atelier sous l'Éclipse",
  "numberOfItems": couteauxTries.length,
  "itemListElement": couteauxTries.map((item, index) => {
    const firstImage = Array.isArray(item.data.image) ? item.data.image[0] : item.data.image;
    
    return {
      "@type": "ListItem",
      "position": index + 1,
      "item": {
        "@type": "Product",
        "name": item.data.titre,
        "image": new URL(firstImage || '', Astro.site || 'https://ateliersousleclipse.fr').href,
        "description": item.data.description || "",
        "brand": {
          "@type": "Brand",
          "name": "L'Atelier sous l'Éclipse"
        }
      }
    };
  })
};
---

<BaseLayout
  title="Couteaux Artisanaux & Pièces Uniques | Les Créations de l'Atelier sous l'Éclipse"
  description="Découvrez mes couteaux faits main en France : Couteaux de cuisine, de table, outdoor et modèles d'exception."
  bodyClass="page-couteaux"
  ogImage="/images/og-creations.jpg" 
>
  <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />

  <main class="min-h-screen bg-bg text-text pt-32 pb-20 px-4 md:px-20 overflow-x-hidden">
  <header class="text-center mb-12 fade-slide-left max-w-4xl mx-auto">
    <h1 class="text-3xl md:text-5xl font-serif font-bold mb-8 text-accent reveal-child">
      Les Créations
    </h1>
    
    <div class="space-y-4 px-4 text-lg text-muted leading-relaxed">
      <p class="reveal-child">
        Chaque couteau, chaque <span class="font-serif text-accent font-bold">Hamon</span> est unique.
        Toutes les lames présentées ici sont entièrement façonnées à la main par mes soins à <span class="font-serif text-accent font-bold">l'Atelier sous l'Éclipse</span>.
      </p>
      <p class="reveal-child">
        Vous trouverez mes dernières créations issues d'Instagram, ainsi que des modèles de référence pour vos futurs projets personnalisés.
      </p>
    </div>

    <div class="flex flex-wrap md:justify-center gap-2 md:gap-4 mt-10 no-select filter-grid">
      <button class="filter-btn active" data-filter="dispo">📦 Disponibles</button>
      <button class="filter-btn" data-filter="all">Galerie</button>
      <button class="filter-btn" data-filter="modele">⚒️ Les Modèles</button>
      <button class="filter-btn" data-filter="video">🎬 Vidéos</button>
    </div>
  </header>

  <div id="knife-grid" class="grid grid-cols-2 md:grid-cols-2 lg:grid-cols-3 gap-3 md:gap-12 max-w-7xl mx-auto">
  {couteauxTries.map((item) => {
    const rawImage = item.data.image;
    const imagePath = Array.isArray(rawImage) ? rawImage[0] : rawImage;
    if (!imagePath) return null;

    const isVideo = item.data.type === "video" || item.data.format === "video";
    const estDispo = item.data.disponible === true || String(item.data.disponible) === "true";
    const typeFiltre = isVideo ? 'video' : (item.data.type || 'insta');
    const urlInsta = item.data.lienInstagram || "#";

    // PATCH : Identification du modèle Table
    const isTableModel = item.data.titre.toLowerCase().includes("table");

    return (
      <article 
        class="knife-card fade-in-up relative flex flex-col h-full bg-surface shadow-lg rounded-lg border-2 border-transparent transition-all duration-500"
        data-type={typeFiltre}
        data-dispo={String(estDispo)}
      >
        <div class="tampon-container absolute -top-8 -right-8 z-[100] w-32 h-32 pointer-events-none drop-shadow-2xl rotate-12">
          {estDispo ? (
            <img src="/images/tampon-dispo.webp" alt="Disponible" class="w-full h-full object-contain" />
          ) : (
            (item.data.prix > 0) && (
              <img src="/images/tampon-vendu.webp" alt="Vendu" class="w-full h-full object-contain" />
            )
          )}
        </div>

        {/* SECTION IMAGE / CANVAS */}
        <div class={`w-full relative overflow-hidden border-b-4 border-[var(--color-accent)] bg-[#1a1a1a] rounded-t-sm ratio-insta ${isTableModel ? 'hamon-scratcher-container' : ''}`}>
          {isTableModel ? (
            /* PATCH : Pour le modèle table, on laisse la div vide. 
               Le script JS injectera le Canvas et l'Image de fond ici.
            */
            <div class="scratcher-placeholder absolute inset-0 flex items-center justify-center text-accent/20 italic">
               Chargement du Hamon...
            </div>
          ) : (
            /* Comportement standard pour les autres couteaux */
            isVideo ? (
              <a href={urlInsta} target="_blank" rel="noopener noreferrer" class="absolute inset-x-0 top-0 bottom-0 z-[10] flex items-center justify-center group cursor-pointer pointer-events-auto">
                <Image src={imagePath} alt={item.data.titre} width={500} height={625} format="webp" class="w-full h-full object-contain opacity-70 transition-all duration-500 group-hover:opacity-100 group-hover:scale-105" />
                <div class="absolute bottom-6 left-1/2 -translate-x-1/2 pointer-events-none">
                  <img src="/images/play-button.webp" alt="Play" class="w-16 h-16 drop-shadow-[0_10px_10px_rgba(0,0,0,0.5)] transition-transform duration-300 group-hover:scale-110" />
                </div>
              </a>
            ) : (
              <a href={imagePath} class="absolute inset-x-0 top-0 bottom-0 z-[10] flex items-center justify-center glightbox-insta cursor-pointer pointer-events-auto" data-title={item.data.titre}>
                <Image src={imagePath} alt={item.data.titre} width={500} height={625} format="webp" class="w-full h-full object-contain transition-transform duration-700 hover:scale-105" />
              </a>
            )
          )}
        </div>

        <div class="p-3 md:p-8 flex flex-col flex-grow bg-[#f0e8dd] relative">
          <div class="flex justify-between items-start mb-1">
            <h3 class="text-sm md:text-2xl font-serif font-bold text-[#7a2a2a] leading-tight flex-1 min-w-0">{item.data.titre}</h3>
            <button class="toggle-details md:hidden text-[#7a2a2a] p-1 focus:outline-none" aria-label="Voir détails">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
          </div>

          <div class="details-content">
            <div class="min-h-0">
              <div class="flex flex-col gap-1 mb-3 py-2 border-y border-[#7a2a2a]/10">
                {item.data.caracteristiques?.acier && (
                  <div class="flex items-baseline gap-2">
                    <span class="text-[10px] font-bold uppercase text-[#7a2a2a]/60 w-12 shrink-0">Acier</span>
                    <span class="text-[11px] font-mono text-[#4a4a4a] italic">{item.data.caracteristiques.acier}</span>
                  </div>
                )}
                {item.data.caracteristiques?.manche && (
                  <div class="flex items-baseline gap-2">
                    <span class="text-[10px] font-bold uppercase text-[#7a2a2a]/60 w-12 shrink-0">Manche</span>
                    <span class="text-[11px] font-mono text-[#4a4a4a] line-clamp-1">{item.data.caracteristiques.manche}</span>
                  </div>
                )}
                {item.data.description && (
                  <p class="text-[11px] md:text-sm text-gray-700 leading-relaxed mt-2 pt-2 border-t border-black/5">
                    {item.data.description}
                  </p>
                )}
              </div>
            </div>
          </div>

          <div class="mt-auto pt-2 md:pt-4 border-t border-black/10 flex flex-col md:flex-row justify-between items-center gap-3 md:gap-2 relative z-[60]"> 
  
  <div class="text-center md:text-left">
    <span class="text-[13px] md:text-xl font-serif font-bold text-[#7a2a2a]">
      {item.data.prix > 0 ? `${item.data.prix} €` : "Sur commande"}
    </span>
  </div>
  
  <span 
    role="button"
    tabindex="0"
    class="trigger-booking-global w-full md:w-auto cursor-pointer px-5 py-2 md:px-5 md:py-2.5 rounded font-bold text-[10px] md:text-xs uppercase tracking-wider transition-all active:scale-95 shadow-md bg-[var(--color-accent)] text-[var(--color-bg)] hover:bg-[#7a2a2a] text-center"
    style={!estDispo ? "background-color: transparent; border: 2px solid var(--color-accent); color: var(--color-accent);" : ""}
    data-ref={item.data.titre}
    data-dispo={String(estDispo)}
  >
    {estDispo ? 'Réserver' : 'Demander'}
  </span>

</div>
      </article>
    );
  })}
</div>
</main>
  
<div id="booking-modal" class="fixed inset-0 z-[999] items-center justify-center p-4">
    <div class="absolute inset-0 bg-black/80 backdrop-blur-sm modal-overlay"></div>
    
    <div class="relative bg-[#f0e8dd] w-full max-w-lg rounded-xl shadow-2xl border border-[#7a2a2a]/20 overflow-hidden transform transition-all">
      <button class="close-x-btn absolute top-4 right-4 text-[#7a2a2a] hover:rotate-90 transition-transform text-2xl z-10">✕</button>
      
      <div class="p-8">
        <h2 id="modal-title" class="text-3xl font-serif font-bold text-[#7a2a2a] mb-2">Réserver ce couteau</h2>
        <p id="modal-ref" class="text-sm font-bold uppercase tracking-widest text-[#7a2a2a]/60 mb-6 italic">Référence : </p>
        
        <form class="space-y-4" action="/contact.php" method="POST">
          <input type="hidden" id="modal-input-ref" name="ref_couteau">
          
          <div class="grid grid-cols-2 gap-4">
            <input type="text" name="nom" placeholder="Votre nom" class="bg-white/50 border border-[#7a2a2a]/20 p-3 rounded outline-none focus:border-[#7a2a2a]" required>
            <input type="email" name="email" placeholder="Votre email" class="bg-white/50 border border-[#7a2a2a]/20 p-3 rounded outline-none focus:border-[#7a2a2a]" required>
          </div>
          
          <textarea id="modal-msg" name="message" rows="5" class="w-full bg-white/50 border border-[#7a2a2a]/20 p-3 rounded outline-none focus:border-[#7a2a2a] resize-none" required></textarea>
          
          <button type="submit" class="w-full bg-[#7a2a2a] text-[#f0e8dd] font-bold py-4 rounded hover:bg-black transition-colors uppercase tracking-widest shadow-lg">
            Envoyer la demande
          </button>
        </form>
      </div>
    </div>
  </div>

  
<!-- ========================================================= -->
<!-- SECTION : Inspiration + Galerie hamon (Embla Carousel)  -->
<!-- ========================================================= -->
<section class="w-full max-w-none bg-surface py-16 inspiration-section">

  <!-- 📝 TEXTE -->
  <div class="max-w-6xl mx-auto px-4 space-y-6 text-center fade-slide-up">
    <h2 class="text-3xl md:text-4xl font-serif font-bold text-accent reveal-child">
      Inspiration
    </h2>
    <p class="text-lg text-muted leading-relaxed reveal-child">
      L’esthétique japonaise, sobre et naturelle, m’inspire profondément. 
      J’aime travailler des matières authentiques pour les manches : textures brutes, couleurs organiques.
    </p>
    <p class="text-lg text-muted leading-relaxed reveal-child">
      Sur beaucoup de mes créations, vous remarquerez une “ligne” sur la lame : le <i class="font-serif italic text-accent">Hamon</i>. 
      Parfois fluide, parfois indomptée, c’est la signature laissée par la trempe sélective — 
      un savoir-faire ancestral japonais. Chaque hamon est unique, fruit de l’acier, du feu et du geste.
    </p>
  </div>

  <!-- 🎠 CAROUSEL -->
  <div class="fade-slide-up mt-10">
    <div class="embla mx-auto">
      <div class="embla__viewport">
        <div class="embla__container">
          {[
            "hamon-1",
            "hamon-2",
            "hamon-3",
            "hamon-4",
            "hamon-5",
            "hamon-6"
          ].map(name => (
            <div class="embla__slide" key={name}>
              <div class="embla__parallax">
                <div class="embla__parallax__layer">
                  <img 
                    src={`/images/slider/${name}.webp`} 
                    alt={`Détail de couteau artisanal avec hamon atelier sous l'éclipse - ${name}`} 
                    class="embla__parallax__img" 
                    loading="lazy"
                  />
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Contrôles Embla -->
      <div class="embla__controls mt-4 flex items-center justify-between">
        <div class="embla__buttons flex gap-2">
          <button class="embla__button embla__button--prev" type="button" aria-label="Précédent"></button>
          <button class="embla__button embla__button--next" type="button" aria-label="Suivant"></button>
        </div>
        <div class="embla__dots flex gap-2"></div>
      </div>
    </div>
  </div>

</section>
<style is:global>
  /* --- 1. CORRECTIF CHIRURGICAL GLIGHTBOX (Tous écrans) --- */
  .glightbox-container .gslide-inner-content,
  .glightbox-container .ginner-container,
  .glightbox-container .gslide-image,
  .glightbox-container .gslide-media {
    box-shadow: none !important;
    background: transparent !important;
  }

  .glightbox-container .gslide-description {
    background: transparent !important;
    box-shadow: none !important;
    border: none !important;
  }

  .glightbox-container .gslide-title {
    color: white !important;
    text-shadow: 0 2px 4px rgba(0,0,0,0.8);
    text-align: center;
    font-family: serif;
  }

  .gslide-image img {
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.6) !important;
    width: auto !important;
    height: auto !important;
    max-width: 95vw !important;
    max-height: 75vh !important;
    display: block !important;
    margin: 0 auto !important;
  }

  /* --- 2. STYLE MOBILE (Max 768px) --- */
  @media (max-width: 768px) {
    #knife-grid {
    display: grid !important;
    grid-template-columns: repeat(2, 1fr) !important;
    grid-auto-rows: 1fr !important; /* MAGIE : Force toutes les fiches d'une ligne à la même hauteur */
    gap: 12px !important;
  }

  .knife-card {
    height: 100% !important; /* La carte occupe toute la place allouée par grid-auto-rows */
    display: flex !important;
    flex-direction: column !important;
  }

    /* On s'assure que le conteneur d'image, lui, reste bien propre */
    .ratio-insta {
      overflow: hidden !important;
      border-radius: 8px 8px 0 0; /* Pour garder les coins arrondis en haut */
    }

    .tampon-container {
      width: 65px !important; /* On peut le remonter un poil en taille */
      height: 65px !important;
      top: -15px !important; /* On le fait dépasser à nouveau */
      right: -15px !important;
      z-index: 110 !important; /* On le passe devant tout */
      pointer-events: none;
    }

    /* Titre : Passage sur 2 lignes pour éviter le crop */
    .knife-card h3 {
      font-size: 13px !important;
      line-height: 1.2 !important;
      min-height: 32px !important;
      max-height: none !important;
      display: block !important;
      overflow: visible !important;
      white-space: normal !important;
      flex: 1;
      margin-bottom: 4px !important;
      padding-right: 4px;
    }

    /* Flèche de détails : Calée en haut à droite */
    .toggle-details {
      align-self: flex-start;
      margin-top: 2px;
      flex-shrink: 0;
    }

    /* Accordéon détails */
    .details-content {
      display: grid !important;
      grid-template-rows: 0fr;
      opacity: 0;
      transition: grid-template-rows 0.4s ease, opacity 0.3s ease;
      overflow: hidden;
    }

    .details-content.is-open {
      grid-template-rows: 1fr;
      opacity: 1;
      padding-top: 4px;
    }

    .details-content .flex.flex-col.gap-1.py-2 {
      border-bottom: none !important; 
      margin-bottom: 0 !important;
      padding-bottom: 0 !important;
    }

    /* Footer de carte : Stack Vertical (Prix au dessus du bouton) */
    .knife-card .mt-auto {
      margin-top: auto;
      padding-top: 10px;
      border-top: 1px solid rgba(122, 42, 42, 0.1) !important;
      display: flex !important;
      flex-direction: column !important;
      align-items: center !important;
      gap: 8px !important;
    }

    .mt-auto span.font-serif {
      font-size: 13px !important;
      display: block !important;
      text-align: center;
      white-space: normal !important;
    }

    .trigger-booking-global {
      width: 100% !important;
      max-width: 130px; /* Largeur optimale pour mobile */
      margin: 0 auto;
      flex-shrink: 0 !important;
      text-align: center;
      padding: 8px 4px !important;
    }
  }

  /* --- 3. CONTENEUR HAMON SCRATCHER --- */
  .hamon-scratcher-container canvas,
  .hamon-scratcher-container .scratcher-placeholder {
    position: absolute;
    top: 0;
    left: 0;
    width: 100% !important;
    height: 100% !important;
    object-fit: cover !important;
    display: block;
    margin: 0;
    padding: 0;
  }
</style>
</BaseLayout>


<script>
  import { initFilters } from '../scripts/features/knife-filters.js';
  import { initBookingLogic } from '../scripts/features/booking-modal.js';
  import { initHamonScratcher } from '../scripts/features/hamon-easter-egg.js'; // L'import propre
  import EmblaCarousel from 'embla-carousel';
  import { initEmbla } from '../scripts/init/init-embla.js';
  import GLightbox from 'glightbox';
  import 'glightbox/dist/css/glightbox.min.css';

  let lightboxInstance = null;

  function initAccordion() {
    // Ton code accordéon existant...
    document.querySelectorAll('.toggle-details').forEach(btn => {
      btn.onclick = (e) => {
        e.preventDefault(); e.stopPropagation();
        const content = btn.closest('.knife-card').querySelector('.details-content');
        btn.classList.toggle('active');
        content.classList.toggle('is-open');
        const svg = btn.querySelector('svg');
        if (svg) svg.style.transform = content.classList.contains('is-open') ? 'rotate(180deg)' : 'rotate(0deg)';
      };
    });
  }

  function initPage() {
    document.querySelectorAll('.embla').forEach((root) => initEmbla(root, EmblaCarousel));
    
    initFilters();
    initBookingLogic();
    initAccordion();
    initHamonScratcher(); // On appelle juste la fonction exportée

    if (lightboxInstance) lightboxInstance.destroy();
    lightboxInstance = GLightbox({ 
        selector: 'a.glightbox-insta', 
        skin: 'hamon', 
        touchNavigation: true, 
        loop: true, 
        zoomable: false, 
        draggable: true 
    });
  }

  document.addEventListener('astro:page-load', initPage);
  if (document.readyState !== 'loading') { 
    if (!window.astroPageLoadExecuted) initPage(); 
  } else { 
    document.addEventListener('DOMContentLoaded', initPage); 
  }
</script>