---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';

const tousLesCouteaux = await getCollection('couteaux');
const couteauxTries = tousLesCouteaux.sort((a, b) => {
  return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
});

const schemaData = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Les Créations de l'Atelier sous l'Éclipse",
  "itemListElement": couteauxTries.map((couteau, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "item": {
      "@type": "Product",
      "name": couteau.data.titre,
      "image": new URL(couteau.data.image, Astro.site || 'https://ateliersousleclipse.fr').href,
      "offers": {
        "@type": "Offer",
        "price": couteau.data.prix > 0 ? couteau.data.prix : undefined,
        "priceCurrency": "EUR"
      }
    }
  }))
};
---

<BaseLayout
  title="Couteaux Artisanaux & Pièces Uniques | Les Créations de l'Atelier sous l'Éclipse"
  description="Découvrez mes couteaux faits main en France : Couteaux de cuisine, de table, outdoor et modèles d'exception."
  bodyClass="page-couteaux"
  ogImage="/images/og-creations.jpg" 
>
  <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />

  <main class="min-h-screen bg-bg text-text pt-32 pb-20 px-4 md:px-20">
    <header class="text-center mb-16 fade-in">
      <h1 class="text-4xl md:text-6xl font-serif font-bold text-[var(--color-accent)] mb-6">Les Créations</h1>
      <div class="flex flex-wrap justify-center gap-4 mt-8 no-select">
        <button class="filter-btn active" data-filter="all">Tout voir</button>
        <button class="filter-btn" data-filter="dispo">📦 Disponibles</button>
        <button class="filter-btn" data-filter="modele">⚒️ Les Modèles</button>
      </div>
    </header>

    <div id="knife-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12 max-w-7xl mx-auto">
      {couteauxTries.map((couteau) => {
        const estDispo = couteau.data.disponible === true || couteau.data.disponible === "true";
        const contactHref = `#contact?ref=${encodeURIComponent(couteau.data.titre)}`;

        return (
          <article 
            class="knife-card fade-in-up relative flex flex-col h-full bg-surface shadow-lg rounded-lg border-4 border-transparent hover:border-[var(--color-accent)] transition-all duration-500"
            data-type={couteau.data.type || 'insta'}
            data-dispo={String(couteau.data.disponible)}
          >
            {estDispo && (
              <div class="absolute -top-12 -right-12 z-40 w-40 h-40 pointer-events-none drop-shadow-2xl rotate-12">
                <img src="/images/tampon-dispo.webp" alt="Disponible" class="w-full h-full object-contain" />
              </div>
            )}

            {/* ICÔNE INSTAGRAM */}
            {couteau.data.lienInstagram && (
              <a 
                href={couteau.data.lienInstagram} 
                target="_blank" 
                rel="noopener noreferrer" 
                class="absolute top-4 left-4 z-50 w-10 h-10 bg-black/60 backdrop-blur-sm p-2 rounded-full border border-white/20 hover:scale-110 hover:bg-[var(--color-accent)] transition-all duration-300 shadow-md flex items-center justify-center text-white" 
                title="Voir sur Instagram"
              >
                <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24" class="w-6 h-6"><path d="M7.5 2h9A5.5 5.5 0 0 1 22 7.5v9A5.5 5.5 0 0 1 16.5 22h-9A5.5 5.5 0 0 1 2 16.5v-9A5.5 5.5 0 0 1 7.5 2zm0 2A3.5 3.5 0 0 0 4 7.5v9A3.5 3.5 0 0 0 7.5 20h9a3.5 3.5 0 0 0 3.5-3.5v-9A3.5 3.5 0 0 0 16.5 4h-9zM12 7a5 5 0 1 1 0 10 5 5 0 0 1 0-10zm0 2a3 3 0 1 0 0 6 3 3 0 0 0 0-6zm5.75-2.25a1.25 1.25 0 1 1-2.5 0 1.25 1.25 0 0 1 2.5 0z"/></svg>
              </a>
            )}

            {/* IMAGE + LIEN LIGHTBOX AVEC FORÇAGE RATIO */}
            <div class="w-full relative overflow-hidden border-b-4 border-[var(--color-accent)] bg-[#1a1a1a] rounded-t-sm" style="padding-top: 125%;">
              <a 
                href={couteau.data.image} 
                class="glightbox-insta absolute top-0 left-0 w-full h-full flex items-center justify-center" 
                data-title={couteau.data.titre}
                data-glightbox="width: auto; height: 82vh; zoomable: false;"
              >
                <Image 
                  src={couteau.data.image} 
                  alt={`Couteau artisanal : ${couteau.data.titre}`} 
                  width={500} 
                  height={625} 
                  format="webp" 
                  class="w-full h-full object-contain transition-transform duration-700 hover:scale-105" 
                />
              </a>
            </div>

            <div class="p-8 flex flex-col flex-grow bg-[#f0e8dd]">
              <h3 class="text-2xl font-serif font-bold text-[#7a2a2a] mb-4">{couteau.data.titre}</h3>
              <p class="text-base text-gray-700 leading-relaxed mb-8 line-clamp-3">
                {couteau.data.description ? couteau.data.description.replace(/\\n/g, '\n') : "Couteau artisanal fait main."}
              </p>

              <div class="mt-auto pt-4 border-t border-black/10 flex justify-between items-center gap-4">
                <span class="text-xl font-serif font-bold text-[var(--color-text)]">
                  {couteau.data.prix > 0 ? `${couteau.data.prix} €` : "Sur commande"}
                </span>
                
                <a href={contactHref} class={`px-5 py-2.5 rounded font-bold text-xs uppercase tracking-wider transition-all active:scale-95 shadow-md ${estDispo ? 'bg-[var(--color-accent)] text-[var(--color-bg)] hover:bg-[var(--color-accent-light)]' : 'border-2 border-[var(--color-accent)] text-[var(--color-accent)] hover:bg-[var(--color-accent)] hover:text-[var(--color-bg)]'}`}>
                  {estDispo ? 'Réserver' : 'Demander'}
                </a>
              </div>
            </div>
          </article>
        );
      })}
    </div>
  </main>
</BaseLayout>

<style>
  .filter-btn { @apply px-6 py-2 border-2 rounded-full transition-all duration-300 font-serif italic text-[var(--color-muted)]; border-color: rgba(255, 255, 255, 0.1); }
  .filter-btn:hover { border-color: var(--color-accent); color: var(--color-accent); }
  .filter-btn.active { background-color: var(--color-accent); color: white; border-color: var(--color-accent); }
  
  .knife-card.hidden { display: none !important; opacity: 0; }
  
  /* Animations */
  .fade-in-up { opacity: 0; transform: translateY(20px); transition: all 0.6s ease-out; }
  .fade-in-up.visible { opacity: 1; transform: translateY(0); }

  /* --- FIX RADICAL POUR LE CROP LIGHTBOX --- */
  :global(.glightbox-container .gslide-image) {
    max-height: 82vh !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    background: transparent !important;
  }

  :global(.glightbox-container .gslide-image img) {
    max-height: 82vh !important;
    width: auto !important;
    height: auto !important;
    object-fit: contain !important; /* Empeche le crop */
  }
</style>

<script>
  import { initRevealOnScroll } from '../scripts/animations/reveal-on-scroll.js';
  import GLightbox from 'glightbox';
  import 'glightbox/dist/css/glightbox.min.css';

  function initFilters() {
    const buttons = document.querySelectorAll('.filter-btn');
    const cards = document.querySelectorAll('.knife-card');
    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        buttons.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        const filter = btn.getAttribute('data-filter');
        cards.forEach(card => {
          const type = card.getAttribute('data-type');
          const isDispo = card.getAttribute('data-dispo') === 'true';
          if (filter === 'all') card.classList.remove('hidden');
          else if (filter === 'dispo') isDispo ? card.classList.remove('hidden') : card.classList.add('hidden');
          else if (filter === 'modele') type === 'modele' ? card.classList.remove('hidden') : card.classList.add('hidden');
        });
        initRevealOnScroll();
      });
    });
  }

  function initPageLightbox() {
    GLightbox({
      selector: '.glightbox-insta',
      skin: 'hamon',
      touchNavigation: true,
      loop: true,
      openEffect: 'fade',
      closeEffect: 'fade',
      closeOnBackdropClick: true
    });
  }

  function setupPage() {
    initFilters();
    initRevealOnScroll();
    initPageLightbox();
  }

  document.addEventListener('astro:page-load', setupPage);
  setupPage();
</script>