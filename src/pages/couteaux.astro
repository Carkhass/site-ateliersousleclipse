---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';

const tousLesCouteaux = await getCollection('couteaux');
const couteauxTries = tousLesCouteaux.sort((a, b) => {
  return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
});

const schemaData = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Les Créations de l'Atelier sous l'Éclipse",
  "itemListElement": couteauxTries.map((couteau, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "item": {
      "@type": "Product",
      "name": couteau.data.titre,
      "image": new URL(couteau.data.image, Astro.site || 'https://ateliersousleclipse.fr').href,
      "offers": {
        "@type": "Offer",
        "price": couteau.data.prix > 0 ? couteau.data.prix : undefined,
        "priceCurrency": "EUR"
      }
    }
  }))
};
---

<BaseLayout
  title="Couteaux Artisanaux & Pièces Uniques | Les Créations de l'Atelier sous l'Éclipse"
  description="Découvrez mes couteaux faits main en France : Couteaux de cuisine, de table, outdoor et modèles d'exception."
  bodyClass="page-couteaux"
  ogImage="/images/og-creations.jpg" 
>
  <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />

  <main class="min-h-screen bg-bg text-text pt-32 pb-20 px-4 md:px-20 overflow-x-hidden">
    <header class="text-center mb-12 fade-in max-w-4xl mx-auto">
      <h1 class="text-3xl md:text-5xl font-serif font-bold mb-8 text-accent">
        Les Créations
      </h1>
      
      <div class="space-y-4 px-4 text-lg text-muted leading-relaxed">
        <p>
          Vous trouverez ici les couteaux entièrement façonnés à la main par mes soins, à 
          <span class="font-serif italic text-accent">l'Atelier sous l'Éclipse</span>.
        </p>
      </div>

      <div class="flex flex-wrap justify-center gap-4 mt-10 no-select">
        <button class="filter-btn active" data-filter="all">Photos</button>
        <button class="filter-btn" data-filter="dispo">📦 Disponibles</button>
        <button class="filter-btn" data-filter="modele">⚒️ Les Modèles</button>
        <button class="filter-btn" data-filter="video">🎬 Vidéos</button>
      </div>
    </header>

    <div id="knife-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12 max-w-7xl mx-auto">
      {couteauxTries.map((couteau) => {
        const estDispo = couteau.data.disponible === true || couteau.data.disponible === "true";
        const typeFiltre = couteau.data.titre.toLowerCase().includes("en vidéo") ? 'video' : (couteau.data.type || 'insta');

        return (
          <article 
            class="knife-card fade-in-up relative flex flex-col h-full bg-surface shadow-lg rounded-lg border-4 border-transparent hover:border-[var(--color-accent)] transition-all duration-500"
            data-type={typeFiltre}
            data-dispo={String(estDispo)}
          >
            {estDispo && (
              <div class="tampon-container absolute -top-8 -right-8 z-40 w-32 h-32 pointer-events-none drop-shadow-2xl rotate-12">
                <img src="/images/tampon-dispo.webp" alt="Disponible" class="w-full h-full object-contain" />
              </div>
            )}

            <div class="w-full relative overflow-hidden border-b-4 border-[var(--color-accent)] bg-[#1a1a1a] rounded-t-sm" style="padding-top: 125%;">
              <a href={couteau.data.image} class="absolute top-0 left-0 w-full h-full flex items-center justify-center glightbox-insta" data-title={couteau.data.titre}>
                <Image src={couteau.data.image} alt={couteau.data.titre} width={500} height={625} format="webp" class="w-full h-full object-contain transition-transform duration-700 hover:scale-105" />
              </a>
            </div>

            <div class="p-8 flex flex-col flex-grow bg-[#f0e8dd]">
              <h3 class="text-xl md:text-2xl font-serif font-bold text-[#7a2a2a] mb-4">{couteau.data.titre}</h3>
              <p class="text-base text-gray-700 leading-relaxed mb-8 line-clamp-3">{couteau.data.description || "Couteau artisanal fait main."}</p>

              <div class="mt-auto pt-4 border-t border-black/10 flex justify-between items-center gap-4">
                <span class="text-xl font-serif font-bold text-[#7a2a2a]">{couteau.data.prix > 0 ? `${couteau.data.prix} €` : "Sur commande"}</span>
                
                {/* VERSION "FORCE BRUTE" : Indépendante de GLightbox et robuste aux filtres */}
                <span 
                  role="button"
                  tabindex="0"
                  class="trigger-booking-global cursor-pointer px-5 py-2.5 rounded font-bold text-xs uppercase tracking-wider transition-all active:scale-95 shadow-md bg-[var(--color-accent)] text-[var(--color-bg)] hover:bg-[#7a2a2a]"
                  style={!estDispo ? "background-color: transparent; border: 2px solid var(--color-accent); color: var(--color-accent);" : ""}
                  data-ref={couteau.data.titre}
                  data-dispo={String(estDispo)}
                >
                  {estDispo ? 'Réserver' : 'Demander'}
                </span>
              </div>
            </div>
          </article>
        );
      })}
    </div>
  </main>

  <div id="booking-modal">
    <div class="modal-overlay modal-closer"></div>
    <div class="modal-content">
      <button type="button" class="modal-closer close-x-btn">&times;</button>
      <div class="p-2">
        <h2 id="modal-title" class="text-2xl font-serif font-bold text-[#7a2a2a] mb-1"></h2>
        <p id="modal-ref" class="text-sm text-gray-600 mb-6 italic font-medium"></p>
        
        <form action="/contact.php" method="POST" class="contact-form space-y-4 text-left">
          <input type="hidden" name="reference_couteau" id="modal-input-ref">
          <input type="text" name="website" style="display:none !important" tabindex="-1">
          
          <div>
            <label class="block text-[10px] font-bold uppercase text-gray-500 mb-1 ml-1">Nom Complet</label>
            <input type="text" name="nom" required class="w-full p-3 border border-black/10 rounded-lg bg-white/50 text-black outline-none focus:border-[var(--color-accent)]">
          </div>
          <div>
            <label class="block text-[10px] font-bold uppercase text-gray-500 mb-1 ml-1">Votre Email</label>
            <input type="email" name="email" required class="w-full p-3 border border-black/10 rounded-lg bg-white/50 text-black outline-none focus:border-[var(--color-accent)]">
          </div>
          <div>
            <label class="block text-[10px] font-bold uppercase text-gray-500 mb-1 ml-1">Votre Message</label>
            <textarea id="modal-msg" name="message" rows="4" class="w-full p-3 border border-black/10 rounded-lg bg-white/50 text-black outline-none focus:border-[var(--color-accent)] resize-none"></textarea>
          </div>
          
          <button type="submit" class="w-full bg-[var(--color-accent)] text-white py-4 rounded-lg font-bold hover:bg-[#7a2a2a] transition-all shadow-lg active:scale-[0.98]">
            Envoyer la demande
          </button>
        </form>
      </div>
    </div>
  </div>
</BaseLayout>

<style is:global>
  /* --- CONFIGURATION DE LA MODALE --- */
  body.active-modal { overflow: hidden; }
  body.active-modal #booking-modal {
    display: flex !important;
    visibility: visible !important;
    opacity: 1 !important;
  }
  #booking-modal { display: none; position: fixed !important; inset: 0 !important; z-index: 100000 !important; align-items: center; justify-content: center; padding: 16px; }
  .modal-overlay { position: absolute; inset: 0; background: rgba(0, 0, 0, 0.85); backdrop-filter: blur(4px); }
  .modal-content { position: relative; background: #f0e8dd; width: 100%; max-width: 500px; padding: 32px; border-radius: 12px; border: 2px solid var(--color-accent); box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5); animation: modal-pop 0.3s ease-out; }
  @keyframes modal-pop { from { opacity: 0; transform: scale(0.95); } to { opacity: 1; transform: scale(1); } }
  .close-x-btn { position: absolute; top: 10px; right: 16px; font-size: 36px; line-height: 1; color: #7a2a2a; background: none; border: none; cursor: pointer; transition: transform 0.2s; }
  .close-x-btn:hover { transform: scale(1.1); }

  /* --- FILTRES & CARTES --- */
  .filter-btn { @apply px-6 py-2 border-2 rounded-full transition-all font-serif italic text-sm; border-color: rgba(122, 42, 42, 0.2); color: #4a4a4a; }
  .filter-btn.active { background-color: var(--color-accent); color: white; border-color: var(--color-accent); @apply shadow-lg; }
  .knife-card.hidden { display: none !important; }
  .fade-in-up { opacity: 0; transform: translateY(20px); transition: all 0.6s ease-out; }
  .fade-in-up.visible { opacity: 1; transform: translateY(0); }
</style>

<script>
  import { initFilters } from '../scripts/features/knife-filters.js';
  import { popupform } from '../scripts/features/popupform.js';
  import GLightbox from 'glightbox';
  import 'glightbox/dist/css/glightbox.min.css';

  function initPage() {
    // Initialisations standard
    initFilters();
    popupform();
    GLightbox({ selector: '.glightbox-insta', skin: 'hamon' });

    const modal = document.getElementById('booking-modal');
    if (!modal) return;

    // GESTIONNAIRE D'ÉVÉNEMENTS CENTRALISÉ (Délégation sur window)
    window.onclick = (e) => {
      const target = e.target as HTMLElement;
      
      // 1. Détection clic OUVERTURE
      const trigger = target.closest('.trigger-booking-global');
      if (trigger) {
        e.preventDefault();
        e.stopPropagation(); // Sécurité supplémentaire

        const ref = trigger.getAttribute('data-ref');
        const isDispo = trigger.getAttribute('data-dispo') === 'true';

        (document.getElementById('modal-title') as HTMLElement).innerText = isDispo ? "Réserver ce couteau" : "Demander une création";
        (document.getElementById('modal-ref') as HTMLElement).innerText = "Référence : " + ref;
        (document.getElementById('modal-input-ref') as HTMLInputElement).value = ref || '';
        (document.getElementById('modal-msg') as HTMLTextAreaElement).value = isDispo 
          ? `Bonjour Yann,\n\nJe souhaiterais réserver le couteau "${ref}". Est-il encore disponible ?`
          : `Bonjour Yann,\n\nJe suis intéressé par le modèle "${ref}" pour une création personnalisée.`;

        document.body.classList.add('active-modal');
        return;
      }

      // 2. Détection clic FERMETURE (Overlay ou Croix)
      if (target.classList.contains('modal-closer') || target.closest('.modal-closer')) {
        document.body.classList.remove('active-modal');
      }
    };

    // Fermeture avec la touche Échap
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') document.body.classList.remove('active-modal');
    });
  }

  document.addEventListener('astro:page-load', initPage);
  // Secours pour le premier chargement sans navigation Astro
  document.addEventListener('DOMContentLoaded', initPage);
</script>