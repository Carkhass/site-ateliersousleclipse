---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';

const tousLesCouteaux = await getCollection('couteaux');
const couteauxTries = tousLesCouteaux.sort((a, b) => {
  return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
});

const schemaData = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Les Créations de l'Atelier sous l'Éclipse",
  "itemListElement": couteauxTries.map((couteau, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "item": {
      "@type": "Product",
      "name": couteau.data.titre,
      "image": new URL(couteau.data.image, Astro.site || 'https://ateliersousleclipse.fr').href,
      "offers": {
        "@type": "Offer",
        "price": couteau.data.prix > 0 ? couteau.data.prix : undefined,
        "priceCurrency": "EUR"
      }
    }
  }))
};
---

<BaseLayout
  title="Couteaux Artisanaux & Pièces Uniques | Les Créations de l'Atelier sous l'Éclipse"
  description="Découvrez mes couteaux faits main en France : Couteaux de cuisine, de table, outdoor et modèles d'exception."
  bodyClass="page-couteaux"
  ogImage="/images/og-creations.jpg" 
>
  <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />

  <main class="min-h-screen bg-bg text-text pt-32 pb-20 px-4 md:px-20 overflow-x-hidden">
    <header class="text-center mb-12 fade-in max-w-4xl mx-auto">
      <h1 class="text-3xl md:text-5xl font-serif font-bold mb-8 text-accent reveal-child">
        Les Créations
      </h1>
      
      <div class="space-y-4 px-4">
        <p class="text-lg text-muted leading-relaxed reveal-child">
          Vous trouverez ici les couteaux entièrement façonnés à la main par mes soins, à 
          <span class="font-serif italic text-accent">l'Atelier sous l'Éclipse</span>. 
          Les photos des couteaux sur commande sont à titre d'exemple.
        </p>
        <p class="text-lg text-muted leading-relaxed reveal-child">
          Chaque couteau, chaque <i class="font-serif italic text-accent">Hamon</i> est différent. 
          Pour les matières des manches, me contacter pour connaître les essences à ma disposition pour votre commande !
        </p>
      </div>

      <div class="flex flex-wrap justify-center gap-4 mt-10 no-select">
        <button class="filter-btn active" data-filter="all">Photos</button>
        <button class="filter-btn" data-filter="dispo">📦 Disponibles</button>
        <button class="filter-btn" data-filter="modele">⚒️ Les Modèles</button>
        <button class="filter-btn" data-filter="video">🎬 Vidéos</button>
      </div>
    </header>

    <div id="knife-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12 max-w-7xl mx-auto">
      {couteauxTries.map((couteau) => {
        const estDispo = couteau.data.disponible === true || couteau.data.disponible === "true";
        const estVideo = couteau.data.titre.toLowerCase().includes("en vidéo");
        
        let typeFiltre = 'insta';
        if (estVideo) {
          typeFiltre = 'video';
        } else if (couteau.data.type) {
          typeFiltre = couteau.data.type;
        }

        return (
          <article 
            class="knife-card fade-in-up relative flex flex-col h-full bg-surface shadow-lg rounded-lg border-4 border-transparent hover:border-[var(--color-accent)] transition-all duration-500 group"
            data-type={typeFiltre}
            data-dispo={String(estDispo)}
          >
            {estDispo && (
              /* PATCH : Ajustement des dimensions et positions pour éviter le débordement hors écran */
              <div class="tampon-container absolute -top-8 -right-8 md:-top-12 md:-right-12 z-40 w-32 h-32 md:w-40 md:h-40 pointer-events-none drop-shadow-2xl rotate-12">
                <img src="/images/tampon-dispo.webp" alt="Disponible" class="w-full h-full object-contain" />
              </div>
            )}

            <div class="w-full relative overflow-hidden border-b-4 border-[var(--color-accent)] bg-[#1a1a1a] rounded-t-sm" style="padding-top: 125%;">
              <a 
                href={estVideo ? couteau.data.lienInstagram : couteau.data.image} 
                target={estVideo ? "_blank" : "_self"}
                rel={estVideo ? "noopener noreferrer" : ""}
                class={`absolute top-0 left-0 w-full h-full flex items-center justify-center ${estVideo ? '' : 'glightbox-insta'}`}
                data-title={couteau.data.titre}
                data-glightbox={estVideo ? "" : "width: auto; height: 82vh; zoomable: false;"}
              >
                {estVideo && (
                  <div class="absolute inset-x-0 bottom-6 z-10 flex items-center justify-center drop-shadow-md pointer-events-none group-hover:scale-110 transition-transform duration-300">
                    <img src="/images/play-button.webp" alt="Lancer la vidéo" class="w-16 h-16 object-contain" />
                  </div>
                )}

                <Image 
                  src={couteau.data.image} 
                  alt={`Couteau artisanal : ${couteau.data.titre}`} 
                  width={500} 
                  height={625} 
                  format="webp" 
                  class="w-full h-full object-contain transition-transform duration-700 hover:scale-105" 
                />
              </a>
            </div>

            <div class="p-8 flex flex-col flex-grow bg-[#f0e8dd]">
              <h3 class="text-xl md:text-2xl font-serif font-bold text-[#7a2a2a] mb-4">
                {couteau.data.titre}
              </h3>
              <p class="text-base text-gray-700 leading-relaxed mb-8 line-clamp-3">
                {couteau.data.description ? couteau.data.description.replace(/\\n/g, '\n') : "Couteau artisanal fait main."}
              </p>

              <div class="mt-auto pt-4 border-t border-black/10 flex justify-between items-center gap-4">
                <span class="text-xl font-serif font-bold text-[#7a2a2a]">
                  {couteau.data.prix > 0 ? `${couteau.data.prix} €` : "Sur commande"}
                </span>
                
                <button 
                  class={`open-booking-modal px-5 py-2.5 rounded font-bold text-xs uppercase tracking-wider transition-all active:scale-95 shadow-md ${estDispo ? 'bg-[var(--color-accent)] text-[var(--color-bg)] hover:bg-[var(--color-accent-light)]' : 'border-2 border-[var(--color-accent)] text-[var(--color-accent)] hover:bg-[var(--color-accent)] hover:text-[var(--color-bg)]'}`}
                  data-ref={couteau.data.titre}
                  data-dispo={String(estDispo)}
                >
                  {estDispo ? 'Réserver' : 'Demander'}
                </button>
              </div>
            </div>
          </article>
        );
      })}
    </div>

    {/* MODALE DYNAMIQUE (RÉSERVATION OU COMMANDE) */}
    <div id="booking-modal" class="fixed inset-0 z-[100] hidden items-center justify-center p-4">
      <div class="absolute inset-0 bg-black/80 backdrop-blur-sm close-booking"></div>
      <div class="relative bg-[#f0e8dd] w-full max-w-lg rounded-xl shadow-2xl overflow-hidden border-2 border-[var(--color-accent)]">
        <button class="absolute top-4 right-4 text-2xl text-[#7a2a2a] close-booking hover:scale-110 transition-transform">×</button>
        <div class="p-8">
          <h2 id="booking-title" class="text-2xl font-serif font-bold text-[#7a2a2a] mb-1 text-left"></h2>
          <p id="booking-ref-display" class="text-sm text-gray-600 mb-6 italic font-medium text-left"></p>
          
          <form class="contact-form space-y-4 text-left" action="/contact.php" method="POST">
            <input type="hidden" name="reference_couteau" id="booking-ref-input">
            <input type="text" name="website" style="display:none !important" tabindex="-1" autocomplete="off">
            
            <div>
              <label class="block text-[10px] font-bold uppercase text-gray-500 mb-1 ml-1">Nom Complet</label>
              <input type="text" name="nom" required class="w-full p-3 border border-black/10 rounded-lg bg-white/50 focus:border-[var(--color-accent)] outline-none text-black">
            </div>
            <div>
              <label class="block text-[10px] font-bold uppercase text-gray-500 mb-1 ml-1">Votre Email</label>
              <input type="email" name="email" required class="w-full p-3 border border-black/10 rounded-lg bg-white/50 focus:border-[var(--color-accent)] outline-none text-black">
            </div>
            <div>
              <label class="block text-[10px] font-bold uppercase text-gray-500 mb-1 ml-1">Votre Message</label>
              <textarea id="booking-message" name="message" rows="5" class="w-full p-3 border border-black/10 rounded-lg bg-white/50 focus:border-[var(--color-accent)] outline-none text-black resize-none"></textarea>
            </div>
            
            <button type="submit" id="booking-submit-btn" class="w-full bg-[var(--color-accent)] text-white py-4 rounded-lg font-bold hover:bg-[#7a2a2a] transition-all shadow-lg active:scale-[0.98]">
              Envoyer la demande
            </button>
          </form>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .no-select { @apply py-4; }
  .filter-btn {
    @apply px-6 py-2 border-2 rounded-full transition-all duration-300 
           font-serif italic text-sm md:text-base bg-white/40 backdrop-blur-sm;
    border-color: rgba(122, 42, 42, 0.2); 
    color: #4a4a4a;
  }
  .filter-btn:hover {
    @apply shadow-sm;
    border-color: var(--color-accent);
    color: var(--color-accent);
    background-color: white;
    transform: translateY(-2px);
  }
  .filter-btn.active {
    @apply shadow-lg;
    background-color: var(--color-accent);
    color: white;
    border-color: var(--color-accent);
    transform: translateY(0);
  }
  @media (max-width: 640px) {
    .flex-wrap { @apply justify-center gap-2; }
    .filter-btn { @apply px-4 py-1.5 text-xs; }
    
    /* PATCH : On s'assure que le tampon ne dépasse pas du tout de l'écran mobile */
    .tampon-container {
      right: -0.5rem !important;
      top: -1.5rem !important;
      width: 80px !important;
      height: 80px !important;
    }
  }
  .knife-card.hidden { display: none !important; }
  .fade-in-up { opacity: 0; transform: translateY(20px); transition: all 0.6s ease-out; }
  .fade-in-up.visible { opacity: 1; transform: translateY(0); }

  :global(.glightbox-container .gslide-image img) {
    max-height: 82vh !important;
    object-fit: contain !important;
  }
</style>

<script>
  import { initFilters } from '../scripts/features/knife-filters.js';
  import { initBookingLogic } from '../scripts/features/booking-modal.js';
  import GLightbox from 'glightbox';
  import 'glightbox/dist/css/glightbox.min.css';

  let lightboxInstance = null;

  function setupPage() {
    initFilters();
    initBookingLogic();

    if (lightboxInstance) { lightboxInstance.destroy(); }

    lightboxInstance = GLightbox({
      selector: '.glightbox-insta',
      skin: 'hamon',
      closeOnBackdropClick: true,
      loop: true,
      openEffect: 'fade',
      closeEffect: 'fade'
    });
  }

  document.addEventListener('astro:page-load', setupPage);
</script>