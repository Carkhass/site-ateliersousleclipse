</form>
    </div>

    <div id="msg-club-success" class="hidden py-4">
      <h3 class="text-2xl font-serif font-bold text-accent mb-2">Message envoyé</h3>
      <p class="text-muted text-sm mb-6">Bienvenue dans le carnet. Surveillez votre boîte mail ce vendredi.</p>
      <button id="close-club-success" class="cta-premium px-5 py-3.5 rounded text-white font-bold text-xs uppercase tracking-[0.2em] mt-6 hover:scale-[1.02] active:scale-95 transition-all shadow-lg">
        Fermer
      </button>
    </div>

  </div>
