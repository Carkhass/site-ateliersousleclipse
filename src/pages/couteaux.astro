<div id="club-modal" class="fixed inset-0 z-[120] hidden items-center justify-center p-4">
  <div id="close-club-bg" class="absolute inset-0 bg-black/70 backdrop-blur-md cursor-pointer transition-opacity duration-300 opacity-0"></div>
  
