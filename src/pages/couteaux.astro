---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';

const tousLesCouteaux = await getCollection('couteaux');
const couteauxTries = tousLesCouteaux.sort((a, b) => {
  return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
});

// Remplace ton bloc schemaData par celui-ci :
const schemaData = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Les Créations de l'Atelier sous l'Éclipse",
  "numberOfItems": couteauxTries.length,
  "itemListElement": couteauxTries.map((couteau, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "item": {
      "@type": "Product",
      "name": couteau.data.titre,
      "image": new URL(couteau.data.image, Astro.site || 'https://ateliersousleclipse.fr').href,
      "description": couteau.data.description,
      "brand": {
        "@type": "Brand",
        "name": "L'Atelier sous l'Éclipse"
      },
      // Nouveau : On fusionne acier et manche pour Google
      "material": `${couteau.data.caracteristiques?.acier || ''}, ${couteau.data.caracteristiques?.manche || ''}`.trim().replace(/^,|,$/g, ''),
      "offers": {
        "@type": "Offer",
        "price": couteau.data.prix > 0 ? couteau.data.prix : undefined,
        "priceCurrency": "EUR",
        "availability": (couteau.data.disponible === true || couteau.data.disponible === "true") 
          ? "https://schema.org/InStock" 
          : "https://schema.org/OutOfStock",
        "itemCondition": "https://schema.org/NewCondition"
      }
    }
  }))
};
---

<BaseLayout
  title="Couteaux Artisanaux & Pièces Uniques | Les Créations de l'Atelier sous l'Éclipse"
  description="Découvrez mes couteaux faits main en France : Couteaux de cuisine, de table, outdoor et modèles d'exception."
  bodyClass="page-couteaux"
  ogImage="/images/og-creations.jpg" 
>
  <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />

  <main class="min-h-screen bg-bg text-text pt-32 pb-20 px-4 md:px-20 overflow-x-hidden">
    <header class="text-center mb-12 fade-slide-left max-w-4xl mx-auto">
      <h1 class="text-3xl md:text-5xl font-serif font-bold mb-8 text-accent reveal-child">
        Les Créations
      </h1>
      
      <div class="space-y-4 px-4 text-lg text-muted leading-relaxed">
        <p class="reveal-child">
          Chaque couteau, chaque <span class="font-serif text-accent font-bold">Hamon</span> est unique.
          Toutes les lames présentées ici sont entièrement façonnées à la main par mes soins à <span class="font-serif text-accent font-bold">l'Atelier sous l'Éclipse</span>.
        </p>
        <p class="reveal-child">
          Vous trouverez mes dernières créations issues d'Instagram, ainsi que des modèles de référence pour vos futurs projets personnalisés.
        </p>
      </div>

      <div class="flex flex-wrap justify-center gap-4 mt-10 no-select">
        <button class="filter-btn active" data-filter="all">Photos</button>
        <button class="filter-btn" data-filter="dispo">📦 Disponibles</button>
        <button class="filter-btn" data-filter="modele">⚒️ Les Modèles</button>
        <button class="filter-btn" data-filter="video">🎬 Vidéos</button>
      </div>
    </header>

    <div id="knife-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12 max-w-7xl mx-auto">
      {couteauxTries.map((couteau) => {
        const estDispo = couteau.data.disponible === true || couteau.data.disponible === "true";
        const isVideo = couteau.data.titre.toLowerCase().includes("en vidéo");
        const typeFiltre = isVideo ? 'video' : (couteau.data.type || 'insta');
        
        const urlInsta = couteau.data.lienInstagram || "#";

        return (
          <article 
            class="knife-card fade-in-up relative flex flex-col h-full bg-surface shadow-lg rounded-lg border-4 border-transparent hover:border-[var(--color-accent)] transition-all duration-500"
            data-type={typeFiltre}
            data-dispo={String(estDispo)}
          >
            <div class="tampon-container absolute -top-8 -right-8 z-[100] w-32 h-32 pointer-events-none drop-shadow-2xl rotate-12">
  {estDispo ? (
    <img src="/images/tampon-dispo.webp" alt="Disponible" class="w-full h-full object-contain" />
  ) : (
    /* On n'affiche le tampon Vendu QUE si un prix était défini (donc une vente publique) */
    couteau.data.prix > 0 && (
      <img src="/images/tampon-vendu.webp" alt="Vendu" class="w-full h-full object-contain" />
    )
  )}
</div>

            <div class="w-full relative overflow-hidden border-b-4 border-[var(--color-accent)] bg-[#1a1a1a] rounded-t-sm ratio-insta">
              
              {isVideo ? (
                <a 
                  href={urlInsta} 
                  target="_blank" 
                  rel="noopener noreferrer" 
                  class="absolute inset-x-0 top-0 bottom-0 z-[10] flex items-center justify-center group cursor-pointer pointer-events-auto"
                >
                  <Image 
                    src={couteau.data.image} 
                    alt={couteau.data.titre} 
                    width={500} 
                    height={625} 
                    format="webp" 
                    class="w-full h-full object-contain opacity-70 transition-all duration-500 group-hover:opacity-100 group-hover:scale-105" 
                  />
                  <div class="absolute bottom-6 left-1/2 -translate-x-1/2 pointer-events-none">
                    <img 
                      src="/images/play-button.webp" 
                      alt="Play" 
                      class="w-16 h-16 drop-shadow-[0_10px_10px_rgba(0,0,0,0.5)] transition-transform duration-300 group-hover:scale-110" 
                    />
                  </div>
                </a>
              ) : (
                <a 
                  href={couteau.data.image} 
                  class="absolute inset-x-0 top-0 bottom-0 z-[10] flex items-center justify-center glightbox-insta cursor-pointer pointer-events-auto" 
                  data-title={couteau.data.titre}
                >
                  <Image src={couteau.data.image} alt={couteau.data.titre} width={500} height={625} format="webp" class="w-full h-full object-contain transition-transform duration-700 hover:scale-105" />
                </a>
              )}
            </div>

            <div class="p-8 flex flex-col flex-grow bg-[#f0e8dd]">
              <h3 class="text-xl md:text-2xl font-serif font-bold text-[#7a2a2a] mb-2">{couteau.data.titre}</h3>

              <div class="flex flex-col gap-1 mb-6 py-3 border-y border-[#7a2a2a]/10">
                {couteau.data.caracteristiques?.acier && (
                  <div class="flex items-baseline gap-2">
                    <span class="text-[12px] font-bold uppercase tracking-tight text-[#7a2a2a]/60 w-16 shrink-0">Acier</span>
                    <span class="text-sm font-mono text-[#4a4a4a] font-medium italic">
                      {couteau.data.caracteristiques.acier}
                    </span>
                  </div>
                )}
                
                {couteau.data.caracteristiques?.manche && (
                  <div class="flex items-baseline gap-2">
                    <span class="text-[12px] font-bold uppercase tracking-tight text-[#7a2a2a]/60 w-16 shrink-0">Manche</span>
                    <span class="text-sm font-mono text-[#4a4a4a] font-medium leading-tight">
                      {couteau.data.caracteristiques.manche}
                    </span>
                  </div>
                )}
              </div>

              <p class="text-base text-gray-700 leading-relaxed mb-8 line-clamp-3">
                {couteau.data.description || "Couteau artisanal fait main."}
              </p>

              <div class="mt-auto pt-4 border-t border-black/10 flex justify-between items-center gap-4 relative z-[60]"> 
                <span class="text-xl font-serif font-bold text-[#7a2a2a]">
                  {couteau.data.prix > 0 ? `${couteau.data.prix} €` : "Sur commande"}
                </span>
                
                <span 
                  role="button"
                  tabindex="0"
                  class="trigger-booking-global cursor-pointer px-5 py-2.5 rounded font-bold text-xs uppercase tracking-wider transition-all active:scale-95 shadow-md bg-[var(--color-accent)] text-[var(--color-bg)] hover:bg-[#7a2a2a] hover:scale-105"
                  style={!estDispo ? "background-color: transparent; border: 2px solid var(--color-accent); color: var(--color-accent);" : ""}
                  data-ref={couteau.data.titre}
                  data-dispo={String(estDispo)}
                >
                  {estDispo ? 'Réserver' : 'Demander'}
                </span>
              </div>
            </div>
          </article>
        );
      })}
    </div>
  </main>
  
<div id="booking-modal" class="fixed inset-0 z-[999] items-center justify-center p-4">
    <div class="absolute inset-0 bg-black/80 backdrop-blur-sm modal-overlay"></div>
    
    <div class="relative bg-[#f0e8dd] w-full max-w-lg rounded-xl shadow-2xl border border-[#7a2a2a]/20 overflow-hidden transform transition-all">
      <button class="close-x-btn absolute top-4 right-4 text-[#7a2a2a] hover:rotate-90 transition-transform text-2xl z-10">✕</button>
      
      <div class="p-8">
        <h2 id="modal-title" class="text-3xl font-serif font-bold text-[#7a2a2a] mb-2">Réserver ce couteau</h2>
        <p id="modal-ref" class="text-sm font-bold uppercase tracking-widest text-[#7a2a2a]/60 mb-6 italic">Référence : </p>
        
        <form class="space-y-4" action="/contact.php" method="POST">
          <input type="hidden" id="modal-input-ref" name="ref_couteau">
          
          <div class="grid grid-cols-2 gap-4">
            <input type="text" name="nom" placeholder="Votre nom" class="bg-white/50 border border-[#7a2a2a]/20 p-3 rounded outline-none focus:border-[#7a2a2a]" required>
            <input type="email" name="email" placeholder="Votre email" class="bg-white/50 border border-[#7a2a2a]/20 p-3 rounded outline-none focus:border-[#7a2a2a]" required>
          </div>
          
          <textarea id="modal-msg" name="message" rows="5" class="w-full bg-white/50 border border-[#7a2a2a]/20 p-3 rounded outline-none focus:border-[#7a2a2a] resize-none" required></textarea>
          
          <button type="submit" class="w-full bg-[#7a2a2a] text-[#f0e8dd] font-bold py-4 rounded hover:bg-black transition-colors uppercase tracking-widest shadow-lg">
            Envoyer la demande
          </button>
        </form>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .ratio-insta {
    padding-top: 125%; 
    position: relative;
    isolation: isolate; 
  }
</style>

<script>
  import { initFilters } from '../scripts/features/knife-filters.js';
  import { initBookingLogic } from '../scripts/features/booking-modal.js';
  import GLightbox from 'glightbox';
  import 'glightbox/dist/css/glightbox.min.css';

  let lightboxInstance = null;

  function initPage() {
    initFilters();
    initBookingLogic();

    if (lightboxInstance) {
      lightboxInstance.destroy();
    }

    lightboxInstance = GLightbox({ 
      selector: 'a.glightbox-insta', 
      skin: 'hamon',
      touchNavigation: true,
      loop: true,
      height: 'auto',
      width: 'auto',
      zoomable: false,
      draggable: true
    });
  }

  document.addEventListener('astro:page-load', initPage);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPage);
  } else {
    initPage();
  }
</script>