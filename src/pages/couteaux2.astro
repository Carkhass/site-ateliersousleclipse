---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';

const tousLesCouteaux = await getCollection('couteaux');

const couteauxTries = tousLesCouteaux.sort((a, b) => {
  const dateA = new Date(a.data.date).getTime();
  const dateB = new Date(b.data.date).getTime();
  return dateB - dateA;
});
---

<BaseLayout
  title="Les Créations – Atelier sous l’éclipse"
  description="Découvrez mes créations : modèles permanents et pièces uniques disponibles."
  bodyClass="page-couteaux"
>

  <main class="min-h-screen bg-bg text-text pt-32 pb-20 px-4 md:px-20">
    
    <header class="text-center mb-16">
      <h1 class="text-4xl md:text-6xl font-serif font-bold text-[var(--color-accent)] mb-6">
        Les Créations
      </h1>
      <p class="text-lg text-[var(--color-muted)] italic mb-8">Pièces uniques et modèles de référence.</p>
      
      <div class="flex flex-wrap justify-center gap-4 mt-8 no-select">
        <button class="filter-btn active" data-filter="all">Tout voir</button>
        <button class="filter-btn" data-filter="dispo">📦 Disponibles</button>
        <button class="filter-btn" data-filter="modele">⚒️ Les Modèles</button>
      </div>
    </header>

    <div id="knife-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12 max-w-7xl mx-auto">
      {couteauxTries.map((couteau, index) => (
        <article 
          class="knife-card relative flex flex-col h-full bg-surface shadow-lg rounded-lg overflow-visible border-4 border-transparent hover:border-[var(--color-accent)] transition-all duration-500"
          data-type={couteau.data.type || 'insta'}
          data-dispo={String(couteau.data.disponible)}
        >
          
          {/* TAMPON DISPONIBLE */}
          {(couteau.data.disponible === true || couteau.data.disponible === "true") && (
            <div class="absolute -top-12 -right-12 z-40 w-40 h-40 pointer-events-none drop-shadow-2xl rotate-12">
              <img src="/images/tampon-dispo.webp" alt="Disponible" class="w-full h-full object-contain" />
            </div>
          )}

          {/* BADGE UNIQUEMENT POUR LES MODÈLES */}
          {couteau.data.type === 'modele' && (
            <span class="absolute top-4 left-4 z-30 bg-[var(--color-accent)] text-white px-3 py-1 text-[10px] uppercase tracking-widest rounded shadow-lg font-bold">
              ⚒️ Modèle permanent
            </span>
          )}

          {/* IMAGE */}
          <div class="w-full relative overflow-hidden border-b-4 border-[var(--color-accent)] bg-[#1a1a1a] rounded-t-sm" style="padding-top: 125%;">
            <a 
              href={couteau.data.image} 
              class="glightbox-insta absolute top-0 left-0 w-full h-full flex items-center justify-center" 
              data-title={couteau.data.titre}
              data-description={couteau.data.description}
            >
              <Image 
                src={couteau.data.image} 
                alt={couteau.data.titre} 
                width={500}
                height={625} 
                format="webp"
                quality="mid"
                loading={index < 3 ? "eager" : "lazy"}
                class="w-full h-full object-contain transition-transform duration-700 hover:scale-105"
              />
            </a>
          </div>

          <div class="p-8 flex flex-col flex-grow">
            <h3 class="text-2xl font-serif font-bold text-[var(--color-accent)] mb-4">
              {couteau.data.titre}
            </h3>
            
            <p class="text-base text-[var(--color-muted)] leading-relaxed mb-8 line-clamp-3 overflow-hidden">
              {couteau.data.description ? couteau.data.description.replace(/\\n/g, '\n') : "Couteau artisanal de l'Atelier sous l'éclipse."}
            </p>

            <div class="mt-auto pt-4 border-t border-white/10 flex justify-between items-center">
              <span class="text-xl font-serif font-bold text-text">
                {couteau.data.prix > 0 ? `${couteau.data.prix} €` : "Sur commande"}
              </span>
              
              <a 
                href={couteau.data.lienInstagram || "#"} 
                target="_blank" 
                class="cta-premium px-4 py-2 text-white rounded text-[10px] uppercase tracking-tighter"
              >
                {couteau.data.type === 'modele' ? 'Détails Modèle' : 'Détails Insta'}
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </main>

  <style>
    .filter-btn {
      @apply px-6 py-2 border-2 rounded-full transition-all duration-300 font-serif italic text-[var(--color-muted)];
      border-color: rgba(255, 255, 255, 0.1);
    }
    
    .filter-btn:hover {
      border-color: var(--color-accent);
      color: var(--color-accent);
    }

    .filter-btn.active {
      background-color: var(--color-accent);
      color: white;
      border-color: var(--color-accent);
    }
    
    .knife-card.hidden {
      display: none !important;
    }

    .knife-card {
      animation: fadeIn 0.4s ease-out forwards;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }
  </style>

  <script>
    function initFilters() {
      const buttons = document.querySelectorAll('.filter-btn');
      const cards = document.querySelectorAll('.knife-card');

      buttons.forEach(btn => {
        btn.addEventListener('click', () => {
          buttons.forEach(b => b.classList.remove('active'));
          btn.classList.add('active');

          const filter = btn.getAttribute('data-filter');

          cards.forEach(card => {
            const type = card.getAttribute('data-type');
            const isDispo = card.getAttribute('data-dispo') === 'true';

            if (filter === 'all') {
              card.classList.remove('hidden');
            } else if (filter === 'dispo') {
              isDispo ? card.classList.remove('hidden') : card.classList.add('hidden');
            } else if (filter === 'modele') {
              type === 'modele' ? card.classList.remove('hidden') : card.classList.add('hidden');
            }
          });
        });
      });
    }

    document.addEventListener('astro:page-load', initFilters);
    initFilters();
  </script>

</BaseLayout>