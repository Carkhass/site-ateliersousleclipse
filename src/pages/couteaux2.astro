---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';

const tousLesCouteaux = await getCollection('couteaux');
const couteauxDynamiques = tousLesCouteaux.sort((a, b) => 
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<BaseLayout
  title="Dernières Créations – Atelier sous l’éclipse"
  description="Découvrez mes derniers couteaux artisanaux, mis à jour en direct depuis l'atelier."
  ogImage="/images/og-couteaux.jpg"
  url="https://www.latelier-sous-leclipse.fr/couteaux2"
  bodyClass="page-couteaux"
>

  <main class="min-h-screen bg-bg text-text pt-32 pb-20 px-4 md:px-20">
    
    <header class="knife-category-title fade-slide-up text-center mb-20">
      <h2 class="text-4xl md:text-5xl font-serif font-bold text-[var(--color-accent)] reveal-child">
        Dernières créations
      </h2>
      <p class="text-lg text-[var(--color-muted)] mt-4 reveal-child italic">
        Ces pièces sont extraites automatiquement de mon flux Instagram.
      </p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12 max-w-7xl mx-auto">
      {couteauxDynamiques.length > 0 ? (
        couteauxDynamiques.map((couteau, index) => (
          <article 
            class="flex flex-col h-full bg-surface shadow-lg rounded-lg overflow-hidden border-4 border-transparent hover:border-[var(--color-accent)] transition-all duration-500 fade-slide-up"
            style={`transition-delay: ${index * 100}ms`}
          >
            
            <div class="aspect-square overflow-hidden border-b-4 border-[var(--color-accent)]">
              <a 
                href={couteau.data.image} 
                class="glightbox-insta block w-full h-full" 
                data-gallery="gallery-instagram"
                data-title={couteau.data.titre}
                data-description={couteau.data.description}
              >
                <Image 
                  src={couteau.data.image} 
                  alt={couteau.data.titre} 
                  width={800}
                  height={800}
                  format="webp"
                  quality="mid"
                  class="w-full h-full object-cover transition-transform duration-700 hover:scale-110"
                />
              </a>
            </div>

            <div class="p-8 flex flex-col flex-grow">
              <h3 class="text-2xl font-serif font-bold text-[var(--color-accent)] mb-4">
                {couteau.data.titre}
              </h3>
              
              <p class="text-lg text-[var(--color-muted)] leading-relaxed mb-8 flex-grow">
                {couteau.data.description}
              </p>

              <div class="mt-auto pt-6 border-t border-[var(--color-accent)]/20 flex justify-between items-center">
                <span class="text-xl font-serif font-bold text-text">
                  {couteau.data.prix ? `${couteau.data.prix} €` : "Prix sur demande"}
                </span>
                
                <a 
                  href={couteau.data.lienInstagram} 
                  target="_blank" 
                  rel="noopener noreferrer"
                  class="cta-premium px-4 py-2 text-white rounded text-xs"
                >
                  Détails Insta
                </a>
              </div>
            </div>
          </article>
        ))
      ) : (
        <div class="col-span-full text-center py-20 bg-surface rounded-lg border-2 border-dashed border-[var(--color-accent)]/20">
          <p class="text-lg text-[var(--color-muted)] italic">L'établi est vide pour le moment...</p>
        </div>
      )}
    </div>

  </main>

  <script>
    import { initRevealOnScroll } from '../scripts/animations/reveal-on-scroll.js';
    import { initLightbox } from "../scripts/init/init-swiper-glightbox.js";
    
    if (typeof window !== 'undefined') {
      initRevealOnScroll();
      initLightbox();
    }
  </script>

</BaseLayout>