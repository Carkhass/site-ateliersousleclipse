        </div>
      </div>
      
    </div>

    <div class="btn-vitrine-container reveal flex justify-center w-full px-4">
  <a href="/en/couteaux" 
     class="group relative w-full max-w-[280px] md:max-w-none md:w-auto px-4 py-4 md:px-12 md:py-4 overflow-hidden border border-muted/20 rounded-sm bg-transparent transition-all duration-700 hover:border-accent/50 inline-block text-center"
     aria-label="View the entire collection of custom knives">
    
    <span class="absolute inset-0 w-0 bg-surface/50 transition-all duration-500 ease-out group-hover:w-full"></span>
    
    <span class="relative font-serif text-[15px] sm:text-base md:text-xl uppercase tracking-[0.15em] sm:tracking-[0.2em] md:tracking-[0.5em] text-muted group-hover:text-accent transition-colors duration-500 block whitespace-nowrap">
      Explore the Collection
    </span>
  </a>
</div>
</section>

  <!-- ========================================================= -->
  <!-- SECTION Maker's mark -->
  <!-- ========================================================= -->
<section 
  class={`parallax-section poincon-section relative w-full h-[70vh] md:h-[70vh] mt-12 my-32 overflow-visible z-0 ${agendaAffiche.length > 0 ? '-mt-32' : ''}`} 
  style="clip-path: none;" /* Removed clip-path to use skew instead */
