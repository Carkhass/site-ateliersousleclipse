    <picture>
      <source media="(max-width: 768px)" srcset="/images/fond-poincon-mobile.webp">
      <img 
        src="/images/fond-poincon-parallax2.webp" 
        alt="Close-up of the YJ maker's mark from Atelier sous l'éclipse on a custom blade" 
