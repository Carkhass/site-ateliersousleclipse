        </div>
      </div>

      <div class="vitrine-column reveal" data-delay="4000">
        <div class="vitrine-stack shadow-2xl rounded-sm overflow-hidden bg-surface">
          <img src="/images/vitrine/Ensemble-couteau-table.webp" 
               class="crossfade-img active" 
               alt="Set of handcrafted table knives for fine dining"
               loading="lazy" />
          <img src="/images/vitrine/Couteau-table-olivier.webp" 
               class="crossfade-img" 
               alt="Elegant table knife with olive wood handle"
               loading="lazy" />
