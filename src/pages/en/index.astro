---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content'; 

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "L'Atelier sous l'Éclipse",
  "image": "https://ateliersousleclipse.fr/images/og-home.jpg",
  "description": "French artisan knifemaker specialized in crafting high-end culinary and table knives. Expertise in traditional differential hardening (Hamon).",
  "url": "https://ateliersousleclipse.fr/en",
  "address": {
    "@type": "PostalAddress",
    "address": "793 Chemin du Trêve d'Ars",
    "addressLocality": "Reyrieux",
    "postalCode": "01600",
    "addressCountry": "FR"
  },
  "knowsAbout": ["Custom knifemaking", "Bladesmithing", "Traditional Hamon", "High-end knives"],
  "priceRange": "€€€"
};

// --- PATCHED NEWS LOGIC ---
const toutesLesActus = await getCollection('actus') || [];
const maintenant = new Date();

// 1. Define time margins
const ilYaUnMois = new Date();
ilYaUnMois.setDate(maintenant.getDate() - 30);

const margeVisibilitePasse = new Date();
margeVisibilitePasse.setDate(maintenant.getDate() - 3); // The event remains visible 3 days after its date

// 2. Filter events for the agenda (recent + near future)
const agendaAffiche = toutesLesActus
  .filter(a => a.data.type === 'evenement' && new Date(a.data.date_event || a.data.date) >= ilYaUnMois)
  .sort((a, b) => new Date(a.data.date_event || a.data.date).getTime() - new Date(b.data.date_event || b.data.date).getTime());

// 3. Isolate featured events (Future + passed less than 3 days ago)
const futurs = agendaAffiche.filter(a => {
  // FORCES priority on date_event if it exists
  const dateEffective = a.data.date_event 
    ? new Date(a.data.date_event) 
    : new Date(a.data.date);
    
  return dateEffective >= margeVisibilitePasse;
});

const prochainEvent = futurs[0];
const autresEvents = futurs.slice(1, 4);

// 4. Recent news (all types combined, for the global feed)
const actusRecentes = toutesLesActus
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 4);
---

<BaseLayout 
