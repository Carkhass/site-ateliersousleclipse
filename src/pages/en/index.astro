          </figure>
        </div>

        <div class="swiper-slide">
          <figure>
            <div class="knife-image">
              <img src="/images/cuisine/atelier-sous-leclipse-couteau-artisanal-baby-bonap-noyer.webp" alt="Custom Baby Bon'ap culinary knife by Atelier sous l'éclipse, C100 steel with hamon, walnut wood handle" />
            </div>
