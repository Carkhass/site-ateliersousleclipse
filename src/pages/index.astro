---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content'; 

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "L'Atelier sous l'Éclipse",
  "image": "https://ateliersousleclipse.fr/images/og-home.jpg",
  "description": "Coutelier d'art en France spécialisé dans la fabrication de couteaux de cuisine et de table. Spécialisé en ligne de trempe sélective (Hamon).",
  "url": "https://ateliersousleclipse.fr",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Reyrieux",
    "postalCode": "01600",
    "addressCountry": "FR"
  },
  "knowsAbout": ["Coutellerie artisanale", "Forge", "Hamon japonais", "Couteaux haut de gamme"],
  "priceRange": "€€€"
};

// --- LOGIQUE ACTUS ---
const toutesLesActus = await getCollection('actus');
const maintenant = new Date();
const ilYaUnMois = new Date();
ilYaUnMois.setDate(maintenant.getDate() - 30);

const agendaAffiche = toutesLesActus
  .filter(a => a.data.type === 'evenement' && new Date(a.data.date) >= ilYaUnMois)
  .sort((a, b) => new Date(a.data.date).getTime() - new Date(b.data.date).getTime());

const actusRecentes = toutesLesActus
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 4);

// On isole le prochain (futur uniquement pour la mise en avant)
const futurs = agendaAffiche.filter(a => new Date(a.data.date) >= maintenant);
const prochainEvent = futurs[0];
const autresEvents = futurs.slice(1, 4);
---

<BaseLayout 
  title="Atelier sous l’éclipse – Coutelier artisanal en France"
  description="Découvrez l’Atelier sous l’éclipse : des couteaux artisanaux uniques, entièrement fabriqués main avec passion en France."
  ogImage="/images/og-home.jpg"
  url="https://ateliersousleclipse.fr"
  isHome={true} 
>
  <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />

  <!-- ========================================================= -->
  <!-- SECTION PRESENTATION -->
  <!-- ========================================================= -->

<section class="max-w-[1280px] mx-auto px-4 py-16 grid md:grid-cols-2 gap-12 items-center min-h-[55vh]">
  <div class="relative fade-slide-left">
    <img 
      src="/images/portrait-yann2.webp" 
      alt="Portrait de Yann, artisan coutelier français"
      class="img-zoom max-w-md w-full h-auto rounded-lg shadow-xl object-cover border-4 border-accent mx-auto md:ml-auto"
      tabindex="0"
    />
  </div>
  <div class="fade-slide-left text-center md:text-left">
    <h2 class="text-3xl md:text-4xl font-serif font-bold mb-6 text-accent reveal-child">
      Bienvenue à l’atelier sous l’éclipse
    </h2>
    <p class="text-lg text-muted leading-relaxed mb-4 reveal-child">
      Mon premier langage fut celui des ordinateurs, un univers où la précision est une loi et la patience une vertu.<br />
      Aujourd'hui, je parle une autre langue : celle du métal et du bois.<br />
    </p>
    <p class="text-lg text-muted leading-relaxed mb-6 reveal-child">
      Au fil des années j'ai affiné mon savoir-faire, nourri par la pratique et la passion.<br />
      Aujourd'hui, je mets cette expérience au service de celles et ceux qui recherchent
      des pièces uniques, façonnées avec soin et pensées pour durer.
    </p>
    <a href="/me-connaitre" class="cta-premium inline-block px-6 py-3 text-white rounded reveal-child">
      En savoir plus
    </a>
  </div>
</section>

  <!-- ========================================================= -->
  <!-- SECTION EVENEMENTS -->
  <!-- ========================================================= -->
{agendaAffiche.length > 0 && (
<section class="relative py-32 mt-24 z-10">
  
  <div class="absolute inset-0 bg-[#1a1a1a] shadow-2xl skew-y-[-4deg] scale-x-110 -z-10 origin-center border-y border-white/5"></div>

  <div class="max-w-7xl mx-auto px-4">
    
    <div class="mb-16 text-center md:text-left fade-slide-up">
      <h2 class="text-3xl md:text-4xl font-serif font-bold text-accent reveal-child">
        Les rendez-vous de l'Atelier
      </h2>
      <p class="text-muted mt-2 reveal-child italic">Retrouvez-moi prochainement sur ces évènements</p>
    </div>

    <div class="hidden lg:grid grid-cols-12 gap-10 mb-6 items-center h-6">
      <div class="col-span-3"></div>
      <div class="col-span-9 grid grid-cols-4 gap-8">
        <div class="col-span-2">
          <span class="text-accent text-[11px] font-bold uppercase tracking-[0.3em] flex items-center gap-2">
            <span class="w-6 h-[1px] bg-accent/30"></span> Ma prochaine exposition
          </span>
        </div>
        <div class="col-span-2">
          <span class="text-muted text-[11px] font-bold uppercase tracking-[0.3em]">Suivantes</span>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-start">
      
      <aside class="lg:col-span-3 fade-slide-left bg-[#e8dfd4] p-6 rounded-2xl border border-black/5 shadow-xl h-fit">
        <h3 class="font-serif text-xl text-[#7a1e1e] mb-6 flex items-center gap-2">
          <span>📅</span> Agenda
        </h3>
        <div class="space-y-6">
          {agendaAffiche.map((event, index) => {
            const dateEvent = new Date(event.data.date);
            const isPasse = dateEvent < maintenant;
            const mois = dateEvent.toLocaleDateString('fr-FR', { month: 'short' }).replace('.', '');
            const jour = dateEvent.getDate();
            
            return (
              <div class={`flex items-center gap-4 group transition-opacity ${isPasse ? 'opacity-50' : ''}`} style={`transition-delay: ${index * 100}ms`}>
                <div class={`p-2 rounded text-center min-w-[55px] border ${isPasse ? 'bg-black/5 border-black/10 text-gray-500' : 'bg-accent/10 border-accent/20 text-accent'}`}>
                  <span class={`block text-xs uppercase font-bold leading-none mb-1 ${isPasse ? 'line-through' : ''}`}>{mois}</span>
                  <span class={`text-xl font-bold leading-none ${isPasse ? 'line-through' : ''}`}>{jour}</span>
                </div>
                <div>
                  <div class="flex items-center gap-2">
                    <p class="text-sm font-bold text-[#2b1b1d] leading-tight">{event.data.titre}</p>
                    {isPasse && <span class="text-[10px] bg-black/10 px-1 rounded text-gray-600 uppercase font-bold whitespace-nowrap">Terminé</span>}
                  </div>
                  <p class="text-xs text-gray-600 italic mt-0.5">{event.data.lieu || "Lieu à préciser"}</p>
                </div>
              </div>
            );
          })}
        </div>
      </aside>

      <div class="lg:col-span-9 grid grid-cols-1 md:grid-cols-4 gap-8 items-start">
        {prochainEvent && (
          <div class="md:col-span-2 flex flex-col fade-slide-up mx-auto md:mx-0 w-[85%] md:w-full max-w-[280px] md:max-w-[340px]">
            <span class="lg:hidden text-accent text-[11px] font-bold uppercase tracking-[0.3em] mb-4">Ma prochaine exposition</span>
            
            <a href={prochainEvent.data.lienInstagram} target="_blank" class="group block rounded-2xl overflow-hidden border-4 border-transparent bg-[#f0e8dd] shadow-2xl transition-all duration-500 hover:shadow-accent/20 hover:-translate-y-2">
              <div class="aspect-[3/4] md:aspect-[4/5] overflow-hidden border-b-4 border-accent bg-[#1a1a1a]">
                <img src={prochainEvent.data.image} alt="" class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105" />
              </div>
              <div class="p-5">
                <div class="flex justify-between items-center gap-4">
                  <div>
                    <h4 class="text-lg font-serif font-bold text-[#2b1b1d] group-hover:text-accent transition-colors leading-tight">{prochainEvent.data.titre}</h4>
                    <p class="text-xs text-gray-600 italic mt-1 flex items-center gap-1"><span class="text-accent">📍</span> {prochainEvent.data.lieu}</p>
                  </div>
                  <span class="shrink-0 border border-accent text-accent px-3 py-1 rounded-full text-[9px] font-black uppercase tracking-tighter group-hover:bg-accent group-hover:text-white transition-all">À venir</span>
                </div>
              </div>
            </a>
          </div>
        )}

        <div class="md:col-span-2 flex flex-col fade-slide-right">
          <span class="lg:hidden text-muted text-[11px] font-bold uppercase tracking-[0.3em] mb-4">Suivantes</span>
          <div class="space-y-4">
            {autresEvents.length > 0 ? autresEvents.map((event, index) => (
              
              /* Petites cartes (Figées en clair) */
              <a href={event.data.lienInstagram} target="_blank" class="group flex items-center gap-4 bg-[#e8dfd4]/80 p-3 rounded-xl border border-black/5 hover:bg-[#e8dfd4] hover:border-accent/20 transition-all" style={`transition-delay: ${index * 150}ms`}>
                <div class="w-14 h-14 shrink-0 rounded-lg overflow-hidden border border-black/10">
                  <img src={event.data.image} alt="" class="w-full h-full object-cover opacity-90 group-hover:opacity-100 transition-opacity" />
                </div>
                <div class="min-w-0">
                  <p class="text-[10px] text-accent font-black uppercase">{new Date(event.data.date).toLocaleDateString('fr-FR', { day: 'numeric', month: 'short' })}</p>
                  <h5 class="text-xs font-bold text-[#2b1b1d] truncate group-hover:text-accent transition-colors">{event.data.titre}</h5>
                </div>
              </a>

            )) : (
              <div class="py-10 flex flex-col items-center justify-center border-2 border-dashed border-white/10 rounded-2xl opacity-60">
                 <span class="text-xl mb-2">✨</span>
                 <p class="text-[10px] text-muted italic uppercase font-bold text-center">Plus de dates bientôt</p>
              </div>
            )}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
)}


  <!-- ========================================================= -->
  <!-- SECTION POINÇON -->
  <!-- ========================================================= -->
<section 
  class={`parallax-section poincon-section relative w-screen h-[70vh] md:h-[70vh] overflow-hidden z-0 ${agendaAffiche.length > 0 ? '-mt-32' : 'mt-16'}`} 
  style="clip-path: polygon(0 6%, 100% 0, 100% 94%, 0 100%);"
  data-parallax-speed="300"
  data-parallax-zoom="1.1"
  data-parallax-zoom-strength="0.1"
>
  <div class="absolute inset-0" data-parallax-target>
    <picture>
      <source media="(max-width: 768px)" srcset="/images/fond-poincon-mobile.webp">
      <img 
        src="/images/fond-poincon-parallax.webp" 
        alt="Détail poinçon YJ atelier sous l'éclipse sur lame artisanale" 
        class="w-full h-full object-cover" 
      />
    </picture>
  </div>
  
  <div class="absolute inset-0 bg-gradient-to-b from-[#1a1a1a] via-transparent to-transparent h-32 opacity-50"></div>
  <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/20 to-transparent h-32"></div>
</section>


<!-- ========================================================= -->
<!-- SECTION COUTEAUX - THEME CUISINE -->
<!-- ========================================================= -->
<section class="section-couteaux theme-cuisine relative z-10 -mt-24 pt-48 pb-32">
  <div class="section-2-grid mx-auto px-4 grid gap-12 items-center lg:grid-cols-[65%_35%]">

    <!-- Colonne 1 : Slider couteaux -->
    <div class="swiper my-knives-swiper fade-slide-left">
      <div class="swiper-wrapper">

        <!-- Slide : Nakiri -->
        <div class="swiper-slide">
          <figure>
            <div class="knife-image">
              <img src="/images/cuisine/atelier-sous-leclipse-couteau-artisanal-nakiri-detoure-noyer.png" alt="Couteau de cuisine Nakiri Atelier sous l'éclipse C125U hamon noyer stabilisé" />
            </div>
            <figcaption>Nakiri</figcaption>
          </figure>
        </div>

        <!-- Slide : Petty -->
        <div class="swiper-slide">
          <figure>
            <div class="knife-image">
              <img src="/images/cuisine/atelier-sous-leclipse-couteau-artisanal-detoure-petty-wacapou.png" alt="Couteau de cuisine Petty Atelier sous l'éclipse C125U hamon bois naturel" />
            </div>
            <figcaption>Petty</figcaption>
          </figure>
        </div>

        <!-- Slide : Grand Bon'ap -->
        <div class="swiper-slide">
          <figure>
            <div class="knife-image">
              <img src="/images/cuisine/atelier-sous-leclipse-couteau-artisanal-detoure-grand-bonap-olivier.png" alt="Couteau de cuisine Grand Bon'ap Atelier sous l'éclipse C125U hamon bois d'olivier" />
            </div>
            <figcaption>Grand Bon'ap</figcaption>
          </figure>
        </div>

        <!-- Slide : Gyuto -->
        <div class="swiper-slide">
          <figure>
            <div class="knife-image">
              <img src="/images/cuisine/atelier-sous-leclipse-couteau-artisanal-detoure-gyuto.png" alt="Couteau de cuisine Gyuto Atelier sous l'éclipse C125U hamon hêtre échauffé stabilisé" />
            </div>
            <figcaption>Gyuto</figcaption>
          </figure>
        </div>

        <!-- Slide : Lance à huîtres -->
        <div class="swiper-slide">
          <figure>
            <div class="knife-image">
              <img src="/images/cuisine/atelier-sous-leclipse-couteau-artisanal-detoure-lance-bois-de-fer.png" alt="Couteau de cuisine Lance à huîtres Atelier sous l'éclipse 80CRV2 bois de fer acid stonewash" />
            </div>
            <figcaption>Lance à huîtres</figcaption>
          </figure>
        </div>

        <!-- Slide : Long Bon'ap -->
        <div class="swiper-slide">
          <figure>
            <div class="knife-image">
              <img src="/images/cuisine/atelier-sous-leclipse-couteau-artisanal-detoure-long-bonap-cocobolo.png" alt="Couteau de cuisine Long Bon'ap Atelier sous l'éclipse C125U hamon cocobolo" />
            </div>
            <figcaption>Long Bon'ap</figcaption>
          </figure>
        </div>

        <!-- Slide : Baby Bon'ap -->
        <div class="swiper-slide">
          <figure>
            <div class="knife-image">
              <img src="/images/cuisine/atelier-sous-leclipse-couteau-artisanal-baby-bonap-noyer.png" alt="Couteau de cuisine Baby Bon'ap Atelier sous l'éclipse C100 hamon noyer" />
            </div>
            <figcaption>Baby Bon'ap</figcaption>
          </figure>
        </div>

      </div>

      <!-- Pagination interne -->
      <div class="swiper-pagination"></div>

      <!-- Navigation -->
      <div class="swiper-button-prev"></div>
      <div class="swiper-button-next"></div>
    </div>

    <!-- Colonne 2 : Texte -->
    <div class="fade-slide-right w-3/4 mr-auto">    
      <h2 class="text-3xl md:text-4xl font-serif font-bold mb-6 text-accent reveal-child">
        En cuisine&nbsp;!
      </h2>
      <p class="text-lg text-muted leading-relaxed reveal-child">
        Je prends un plaisir particulier à façonner des couteaux de cuisine — la gourmandise, ça ne s'invente pas ! 
        Donc la plupart de mes créations se destinent aux arts de la table.
      </p>

      <p class="text-lg text-muted leading-relaxed reveal-child">
        Du tranchant précis d'un petty à la puissance d'un grand chef, chaque couteau est pensé pour devenir 
        le prolongement naturel de la main.
      </p>
    </div>

  </div>
</section>

<!-- ========================================================= -->
<!-- SECTION COUTEAUX - THEME TABLE -->
<!-- ========================================================= -->
<section class="section-couteaux theme-table bg-surface">
  <div class="section-2-grid slider-right mx-auto px-4 grid gap-12 items-center lg:grid-cols-[35%_65%]">

    <!-- Colonne 1 : Texte -->
    <div class="fade-slide-left text-right w-3/4 ml-auto"> 
      <h2 class="text-3xl md:text-4xl font-serif font-bold mb-6 text-accent reveal-child">
        À table&nbsp;!
      </h2>
      <p class="text-lg text-muted leading-relaxed reveal-child">
        Mariage de lignes épurées et de matériaux nobles, mes couteaux de table incarnent une vision 
        exigeante de l'art de recevoir... mais rassurez-vous, ils conviendront aussi parfaitement 
        aux repas du quotidien&nbsp;!
      </p>
    </div>

    <!-- Colonne 2 : Slider couteaux -->
    <div class="swiper my-knives-swiper fade-slide-right">
      <div class="swiper-wrapper">

        <!-- Slide : Table1 -->
        <div class="swiper-slide">
          <figure>
            <div class="knife-image">
              <img src="/images/table/atelier-sous-leclipse-couteau-artisanal-table-ebene-aubier.png" alt="Couteau de Table Atelier sous l'éclipse C100 ébène bicolore" />
            </div>
            <figcaption>Ebène bicolore</figcaption>
          </figure>
        </div>

        <!-- Slide : Table2 -->
        <div class="swiper-slide">
          <figure>
            <div class="knife-image">
              <img src="/images/table/atelier-sous-leclipse-couteau-artisanal-table-wacapou.png" alt="Couteau de Table Atelier sous l'éclipse C100 wacapou" />
            </div>
            <figcaption>Wacapou</figcaption>
          </figure>
        </div>

        <!-- Slide : Table3 -->
        <div class="swiper-slide">
          <figure>
            <div class="knife-image">
              <img src="/images/table/atelier-sous-leclipse-couteau-artisanal-table-loupe-peuplier.png" alt="Couteau de Table Atelier sous l'éclipse C100 Loupe peuplier" />
            </div>
            <figcaption>Loupe peuplier</figcaption>
          </figure>
        </div>

      </div>

      <!-- Pagination interne -->
      <div class="swiper-pagination"></div>

      <!-- Navigation -->
      <div class="swiper-button-prev"></div>
      <div class="swiper-button-next"></div>
    </div>

  </div>
</section>

<!-- ========================================================= -->
<!-- SECTION COUTEAUX - THEME OUTDOOR -->
<!-- ========================================================= -->
<section class="section-couteaux theme-outdoor">
  <div class="section-2-grid mx-auto px-4 grid gap-12 items-center lg:grid-cols-[65%_35%]">

    <!-- Colonne 1 : Slider couteaux -->
    <div class="swiper my-knives-swiper fade-slide-left">
      <div class="swiper-wrapper">

        <!-- Slide : Outdoor 1 -->
        <div class="swiper-slide">
          <figure>
            <div class="knife-image">
              <img src="/images/outdoor/atelier-sous-leclipse-couteau-artisanal-camp-manguier.png" alt="Couteau de Camp Atelier sous l'éclipse 80CRV2 Manguier ondé stabilisé" />
            </div>
            <figcaption>Manguier ondé</figcaption>
          </figure>
        </div>

        <!-- Slide : Outdoor 2 -->
        <div class="swiper-slide">
          <figure>
            <div class="knife-image">
              <img src="/images/outdoor/atelier-sous-leclipse-couteau-artisanal-camp-morta.png" alt="Couteau de Camp Atelier sous l'éclipse 80CRV2 morta stabilisé" />
            </div>
            <figcaption>Morta stab</figcaption>
          </figure>
        </div>

        <!-- Slide : Outdoor 3 -->
        <div class="swiper-slide">
          <figure>
            <div class="knife-image">
              <img src="/images/outdoor/atelier-sous-leclipse-couteau-artisanal-camp-ebene.png" alt="Couteau de Camp Atelier sous l'éclipse 80CRV2 ébène" />
            </div>
            <figcaption>Ebène noir</figcaption>
          </figure>
        </div>

        <!-- Slide : Outdoor 4 -->
        <div class="swiper-slide">
          <figure>
            <div class="knife-image">
              <img src="/images/outdoor/atelier-sous-leclipse-couteau-artisanal-fighter-koa.png" alt="Couteau outdoor Fighter Atelier sous l'éclipse 80CRV2 Koa" />
            </div>
            <figcaption>Fighter Koa</figcaption>
          </figure>
        </div>

      </div>

      <!-- Pagination interne -->
      <div class="swiper-pagination"></div>

      <!-- Navigation -->
      <div class="swiper-button-prev"></div>
      <div class="swiper-button-next"></div>
    </div>

    <!-- Colonne 2 : Texte -->
    <div class="fade-slide-right w-3/4 mr-auto"> 
      <h2 class="text-3xl md:text-4xl font-serif font-bold mb-6 text-accent reveal-child">
        En plein air&nbsp;!
      </h2>
      <p class="text-lg text-muted leading-relaxed reveal-child">
        Si vous avez l'esprit d'aventure, que vous aimez les grands espaces, l'odeur des forêts 
        et les sentiers reculés... L'Atelier a quelques compagnons fiables à vous proposer.
      </p>      
      <p class="text-lg text-muted leading-relaxed reveal-child">
        Aciers robustes sélectionnés pour leurs caractéristiques techniques, tranchant robuste pour 
        passer de la coupe fine à l'ouvrage le plus exigeant, mais toujours avec l'empreinte unique de l'atelier.
      </p>

      </p>
    </div>

  </div>
</section>

<script>
  import { initSwipers, initLightbox } from '../scripts/init/init-swiper-glightbox.js';

  if (typeof window !== 'undefined') {
    // Initialise tous les sliders Swiper présents dans la page
    initSwipers();

    // Initialise la lightbox sur les images ciblées
    initLightbox();
  }
</script>



<!-- ========================================================= -->
<!-- SECTION 3 : Inspiration + Galerie hamon (Embla Carousel)  -->
<!-- ========================================================= -->
<section class="w-full max-w-none bg-surface py-16 inspiration-section">

  <!-- 📝 TEXTE -->
  <div class="max-w-6xl mx-auto px-4 space-y-6 text-center fade-slide-up">
    <h2 class="text-3xl md:text-4xl font-serif font-bold text-accent reveal-child">
      Inspiration
    </h2>
    <p class="text-lg text-muted leading-relaxed reveal-child">
      L’esthétique japonaise, sobre et naturelle, m’inspire profondément. 
      J’aime travailler des matières authentiques pour les manches : textures brutes, couleurs organiques.
    </p>
    <p class="text-lg text-muted leading-relaxed reveal-child">
      Sur beaucoup de mes créations, vous remarquerez une “ligne” sur la lame : le <i class="font-serif italic text-accent">Hamon</i>. 
      Parfois fluide, parfois indomptée, c’est la signature laissée par la trempe sélective — 
      un savoir-faire ancestral japonais. Chaque hamon est unique, fruit de l’acier, du feu et du geste.
    </p>
  </div>

  <!-- 🎠 CAROUSEL -->
  <div class="fade-slide-up mt-10">
    <div class="embla mx-auto">
      <div class="embla__viewport">
        <div class="embla__container">
          {[
            "hamon-1",
            "hamon-2",
            "hamon-3",
            "hamon-4",
            "hamon-5",
            "hamon-6"
          ].map(name => (
            <div class="embla__slide" key={name}>
              <div class="embla__parallax">
                <div class="embla__parallax__layer">
                  <img 
                    src={`/images/slider/${name}.webp`} 
                    alt={`Détail de couteau artisanal avec hamon atelier sous l'éclipse - ${name}`} 
                    class="embla__parallax__img" 
                    loading="lazy"
                  />
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Contrôles Embla -->
      <div class="embla__controls mt-4 flex items-center justify-between">
        <div class="embla__buttons flex gap-2">
          <button class="embla__button embla__button--prev" type="button" aria-label="Précédent"></button>
